@using Microsoft.AspNetCore.Identity
@using WebDuLichDaLat.Models
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

@{
    string? capitalizedLastName = null;

    if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        var fullName = user?.FullName;
        var lastName = fullName?.Split(' ').LastOrDefault();
        capitalizedLastName = lastName != null ? char.ToUpper(lastName[0]) + lastName.Substring(1).ToLower() : "";
    }
}

<style>
    .auth-buttons {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .btn-login-nav {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .btn-login-nav:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.5);
        color: white;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .btn-register-nav {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.1));
        border: 2px solid rgba(255, 255, 255, 0.4);
        color: white;
        padding: 8px 20px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
    }

    .btn-register-nav:hover {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.2));
        border-color: rgba(255, 255, 255, 0.6);
        color: white;
        text-decoration: none;
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
    }

    .user-dropdown .dropdown-toggle {
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.2);
        border-radius: 25px;
        padding: 8px 16px;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }

    .user-dropdown .dropdown-toggle:hover {
        background: rgba(255, 255, 255, 0.2);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-1px);
    }

    .user-dropdown .dropdown-menu {
        border: none;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(20px);
        background: rgba(255, 255, 255, 0.95);
        margin-top: 8px;
    }

    .user-dropdown .dropdown-item {
        padding: 10px 20px;
        border-radius: 8px;
        margin: 4px 8px;
        transition: all 0.3s ease;
        font-weight: 500;
    }

    .user-dropdown .dropdown-item:hover {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        transform: translateX(5px);
    }

    .user-dropdown .dropdown-item button {
        background: none;
        border: none;
        color: inherit;
        font-weight: inherit;
        width: 100%;
        text-align: left;
        padding: 0;
    }

    @@media (max-width: 768px) {
        .auth-buttons {
            flex-direction: column;
            gap: 8px;
            width: 100%;
        }

        .btn-login-nav,
        .btn-register-nav {
            width: 100%;
            justify-content: center;
            margin: 2px 0;
        }
    }
</style>

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown user-dropdown">
            <a class="nav-link dropdown-toggle text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-1"></i> @capitalizedLastName
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear me-2"></i>Tài khoản
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form id="logoutForm" method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                        <div class="dropdown-item">
                            <button type="submit">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </button>
                        </div>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <div class="auth-buttons">
                <a class="btn-login-nav" asp-area="Identity" asp-page="/Account/Login">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Đăng nhập
                </a>
                <a class="btn-register-nav" asp-area="Identity" asp-page="/Account/Register">
                    <i class="bi bi-person-plus"></i>
                    Đăng ký
                </a>
            </div>
        </li>
    }
</ul>
