@{
    var categories = ViewBag.Categories as List<WebDuLichDaLat.Models.Category>;
    var regions = ViewBag.Regions as List<WebDuLichDaLat.Models.Region>;
    var touristPlacesList = ViewBag.TouristPlacesList as List<WebDuLichDaLat.Models.TouristPlace> ?? new List<WebDuLichDaLat.Models.TouristPlace>();
}

<!-- Places Overlay Panel -->
<div id="placesPanel" class="places-overlay-panel" style="display: none;">
    <div class="places-panel-content">
        <!-- Top Right Close Button -->
        <div class="d-flex justify-content-end mb-2" style="position: relative;">
            <button class="btn btn-link text-white p-0" style="text-decoration: none; font-size: 20px; z-index: 10;" onclick="closePlacesPanel()">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Three Columns Layout -->
        <div class="row g-4 mb-3">
            <!-- Column 1: Khu vực -->
            <div class="col-lg-4">
                <button class="section-toggle-btn w-100 text-start mb-2 p-2 rounded border-0 d-flex justify-content-between align-items-center" 
                        style="background-color: rgba(255,255,255,0.1); color: white; font-weight: 600; font-size: 22px; cursor: pointer;"
                        onclick="toggleSection('resortSection', this)">
                    <span>Khu vực</span>
                    <i class="bi bi-chevron-down section-icon" style="transition: transform 0.3s ease;"></i>
                </button>
                <div id="resortSection" class="section-content" style="max-height: 0; overflow: hidden; transition: max-height 0.4s ease-out;">
                    <div style="padding: 0 12px 20px 12px;">
                        <ul class="list-unstyled" style="font-size: 15px; line-height: 2;">
                            @if (regions != null && regions.Any())
                            {
                                var displayRegions = regions.Take(5);
                                int index = 0;
                                @foreach (var region in displayRegions)
                                {
                                    <li class="mb-1">
                                        <a href="@Url.Action("Index", "TouristPlace", new { regionId = region.Id })" 
                                           class="@(index == 2 ? "text-decoration-none d-flex align-items-center" : "text-white text-decoration-none d-flex align-items-center")" 
                                           style="@(index == 2 ? "color: #ff6b9d;" : "")">
                                            <span class="me-2">></span>
                                            <span>@region.Name</span>
                                        </a>
                                    </li>
                                    index++;
                                }
                            }
                            else
                            {
                                <li class="mb-1">
                                    <span class="text-white-50">Chưa có dữ liệu khu vực</span>
                                </li>
                            }
                        </ul>
                        <a href="@Url.Action("Index", "TouristPlace")" class="text-white text-decoration-none d-flex align-items-center mt-2" style="font-size: 14px;">
                            Đọc tất cả <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Column 2: Điểm tham quan -->
            <div class="col-lg-4">
                <button class="section-toggle-btn w-100 text-start mb-2 p-2 rounded border-0 d-flex justify-content-between align-items-center" 
                        style="background-color: rgba(255,255,255,0.1); color: white; font-weight: 600; font-size: 22px; cursor: pointer;"
                        onclick="toggleSection('attractionSection', this)">
                    <span>Điểm tham quan</span>
                    <i class="bi bi-chevron-down section-icon" style="transition: transform 0.3s ease;"></i>
                </button>
                <div id="attractionSection" class="section-content" style="max-height: 0; overflow: hidden; transition: max-height 0.4s ease-out;">
                    <div style="padding: 0 12px 20px 12px;">
                        <ul class="list-unstyled" style="font-size: 15px; line-height: 2;">
                            @if (categories != null && categories.Any())
                            {
                                var displayCategories = categories.Take(5);
                                int index = 0;
                                @foreach (var category in displayCategories)
                                {
                                    <li class="mb-1">
                                        <a href="@Url.Action("Index", "TouristPlace", new { categoryId = category.Id })" 
                                           class="@(index == 2 ? "text-decoration-none d-flex align-items-center" : "text-white text-decoration-none d-flex align-items-center")" 
                                           style="@(index == 2 ? "color: #ff6b9d;" : "")">
                                            <span class="me-2">></span>
                                            <span>@category.Name</span>
                                        </a>
                                    </li>
                                    index++;
                                }
                            }
                            else
                            {
                                <li class="mb-1">
                                    <span class="text-white-50">Chưa có dữ liệu danh mục</span>
                                </li>
                            }
                        </ul>
                        <a href="@Url.Action("Index", "TouristPlace")" class="text-white text-decoration-none d-flex align-items-center mt-2" style="font-size: 14px;">
                            Đọc tất cả <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Column 3: Tìm trên bản đồ -->
            <div class="col-lg-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="mb-0" style="font-weight: 600; font-size: 22px;">Tìm trên bản đồ</h2>
                    <a href="@Url.Action("Map", "TouristPlace")" class="text-white text-decoration-none d-flex align-items-center" style="font-size: 14px;">
                        Mở bản đồ <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
                <div id="panelMiniMap" style="width: 100%; height: 200px; border-radius: 10px; overflow: hidden; background-color: #1a1a1a;"></div>
                <div class="mt-2 text-end" style="font-size: 12px; color: rgba(255,255,255,0.7);">
                    <span>100 km</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .places-overlay-panel {
        position: fixed;
        top: 70px;
        left: 0;
        right: 0;
        max-height: calc(100vh - 170px);
        background-color: #210021;
        color: white;
        z-index: 9000;
        overflow-y: auto;
        transform: translateY(-100%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    .places-overlay-panel.open {
        z-index: 9000;
    }

    .places-overlay-panel.open {
        transform: translateY(0);
    }

    .places-panel-content {
        padding: 25px 30px 20px 30px;
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .places-overlay-panel a:hover {
        color: #ff6b9d !important;
        transition: color 0.3s ease;
    }

    .section-toggle-btn {
        transition: all 0.3s ease;
    }

    .section-toggle-btn:hover {
        background-color: rgba(255,255,255,0.15) !important;
    }

    .section-toggle-btn.active {
        background-color: rgba(255,255,255,0.2) !important;
    }

    .section-toggle-btn.active .section-icon {
        transform: rotate(180deg);
    }

    .section-content {
        transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .section-content.open {
        max-height: 1000px !important;
    }


    @@media (max-width: 992px) {
        .places-overlay-panel {
            top: 70px;
            max-height: calc(100vh - 150px);
        }

        .places-panel-content {
            padding: 30px 20px 20px 20px !important;
        }
    }

    @@media (max-width: 768px) {
        .places-overlay-panel {
            top: 60px;
            max-height: calc(100vh - 140px);
        }

        .places-panel-content {
            padding: 20px 15px 15px 15px !important;
        }
    }
</style>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // Initialize mini map in panel
    function initPanelMiniMap() {
        if (typeof L === 'undefined') {
            // Wait for Leaflet to load
            setTimeout(initPanelMiniMap, 100);
            return;
        }
        
        var mapElement = document.getElementById('panelMiniMap');
        if (!mapElement || mapElement.hasChildNodes()) return; // Already initialized

        var miniMap = L.map('panelMiniMap', {
            center: [11.9404, 108.4583], // Đà Lạt
            zoom: 11,
            zoomControl: false,
            attributionControl: false
        });

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19
        }).addTo(miniMap);

        // Add markers for places
        var miniMarkers = [];
        @if (touristPlacesList.Any())
        {
            foreach (var place in touristPlacesList.Take(10))
            {
                if (place.Latitude != 0 && place.Longitude != 0)
                {
                    <text>
                    var marker = L.marker([@place.Latitude, @place.Longitude])
                        .addTo(miniMap)
                        .bindPopup('<b>@place.Name</b>');
                    miniMarkers.push(marker);
                    </text>
                }
            }
        }

        // Fit bounds
        if (miniMarkers.length > 0) {
            var group = new L.featureGroup(miniMarkers);
            miniMap.fitBounds(group.getBounds().pad(0.1));
        }
    }
</script>

