<style>
    .trip-planner-overlay-panel {
        position: fixed;
        top: 70px;
        left: 0;
        right: 0;
        max-height: calc(100vh - 170px);
        background-color: #210021;
        color: white;
        z-index: 9000;
        overflow-y: auto;
        transform: translateY(-100%);
        transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    .trip-planner-overlay-panel.open {
        z-index: 9000;
    }

    .trip-planner-overlay-panel.open {
        transform: translateY(0);
    }

    .trip-planner-panel-content {
        padding: 25px 30px 20px 30px;
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .trip-planner-overlay-panel a:hover {
        color: #ff6b9d !important;
        transition: color 0.3s ease;
    }

    .info-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .info-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(255, 107, 157, 0.3);
    }

    .btn-close-panel:hover {
        background-color: rgba(255, 255, 255, 0.1) !important;
        border-radius: 50%;
    }

    .speech-bubble {
        transition: transform 0.3s ease;
    }

    .speech-bubble:hover {
        transform: scale(1.05);
    }

    .pagination-dots {
        margin-top: 15px;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.3);
        transition: all 0.3s ease;
    }

    .dot.active {
        background-color: #ff6b9d;
        width: 10px;
        height: 10px;
    }

    .weather-chart {
        position: relative;
    }

    .chart-bar {
        transition: transform 0.3s ease;
    }

    .chart-bar:hover {
        transform: translateY(-5px);
    }

    .section-toggle-btn.active .section-icon {
        transform: rotate(180deg);
    }

    @@media (max-width: 768px) {
        .trip-planner-overlay-panel {
            top: 70px;
        }

        .trip-planner-panel-content {
            padding: 20px 15px;
        }

        .countdown-timer {
            font-size: 36px !important;
        }
    }
</style>

<script>
    function toggleTripPlannerSection(sectionId, button) {
        var section = document.getElementById(sectionId);
        if (!section) return;
        
        var isOpen = section.classList.contains('open');
        
        if (isOpen) {
            section.style.maxHeight = section.scrollHeight + 'px';
            section.offsetHeight;
            section.style.maxHeight = '0';
            section.classList.remove('open');
            button.classList.remove('active');
        } else {
            section.style.maxHeight = '0';
            section.classList.add('open');
            section.offsetHeight;
            section.style.maxHeight = section.scrollHeight + 'px';
            button.classList.add('active');
        }
    }
</script>

