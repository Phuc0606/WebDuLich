@model IEnumerable<WebDuLichDaLat.Models.Restaurant>
@{
    ViewData["Title"] = "Danh sách nhà hàng & quán ăn";
    Layout = "~/Views/Shared/_LayoutNoFooter.cshtml";
    var search = ViewBag.Search as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<!-- Import Modern Font -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Hero Section with Glassmorphism -->
<section class="hero-section" style="background: linear-gradient(135deg, rgba(255,142,83,0.15), rgba(255,107,157,0.1)), linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80') center/cover; height: 100vh; display: flex; align-items: center; position: relative; margin-top: 0; padding-top: 80px;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="hero-title mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 3.5rem; font-weight: 800; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); line-height: 1.2;">
                    Nhà Hàng & Ẩm Thực Đà Lạt
                </h1>
                <p class="hero-subtitle mb-5" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.3rem; color: rgba(255,255,255,0.9); text-shadow: 1px 1px 2px rgba(0,0,0,0.5); font-weight: 300;">
                    Khám phá hương vị đặc sắc của thành phố ngàn hoa
                </p>
                <div class="hero-search-box" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.2); border-radius: 25px; padding: 25px; max-width: 600px; margin: 0 auto; box-shadow: 0 25px 50px rgba(0,0,0,0.3);">
                    <form method="get" action="@Url.Action("Index", "Restaurant")" class="d-flex gap-3 align-items-center">
                        <div class="flex-grow-1">
                            <input type="text" name="search" class="form-control modern-search" placeholder="Tìm kiếm nhà hàng, quán ăn..." 
                                   value="@search"
                                   style="border: none; background: rgba(255,255,255,0.9); color: #333; font-size: 16px; padding: 18px 25px; border-radius: 20px; box-shadow: none; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 500;">
                        </div>
                        <button class="btn hero-search-btn" type="submit" style="background: linear-gradient(135deg, #ff8e53, #ff6b9d); color: white; border: none; border-radius: 20px; padding: 18px 35px; font-weight: 600; box-shadow: 0 8px 25px rgba(255,142,83,0.4); font-family: 'Plus Jakarta Sans', sans-serif;">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Floating Neon Glow Effects -->
    <div class="neon-glow-bg">
        <div class="glow-orb glow-orb-1"></div>
        <div class="glow-orb glow-orb-2"></div>
        <div class="glow-orb glow-orb-3"></div>
    </div>
</section>

<!-- Main Content Section -->
<section id="restaurants-section" style="background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%); color: white; min-height: 100vh; padding: 60px 0 40px 0; font-family: 'Plus Jakarta Sans', sans-serif; position: relative; overflow: hidden;">
    <!-- Background Neon Glow -->
    <div class="section-glow-bg">
        <div class="section-glow-orb section-glow-1"></div>
        <div class="section-glow-orb section-glow-2"></div>
        <div class="section-glow-orb section-glow-3"></div>
    </div>
    
    <div class="container-fluid px-4">
        <div class="row">
            <!-- Glassmorphism Sidebar Filters -->
            <div class="col-lg-3 mb-4">
                <div class="filter-sidebar glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; padding: 35px; position: sticky; top: 100px; box-shadow: 0 25px 50px rgba(0,0,0,0.4);">
                    <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white; display: flex; align-items: center; font-family: 'Plus Jakarta Sans', sans-serif;">
                        <div class="filter-icon" style="background: linear-gradient(135deg, #ff8e53, #ff6b9d); width: 45px; height: 45px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                            <i class="bi bi-funnel" style="color: white; font-size: 18px;"></i>
                        </div>
                        Bộ lọc
                    </h3>
                    
                    <!-- Modern Search Form -->
                    <form method="get" action="@Url.Action("Index", "Restaurant")">
                        <div class="mb-4">
                            <label class="form-label modern-label" style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 12px; font-size: 14px; display: flex; align-items: center;">
                                <i class="bi bi-search me-2" style="color: #ff8e53;"></i>Tìm kiếm nhà hàng
                            </label>
                            <input type="text" name="search" class="form-control modern-input" placeholder="Nhập tên nhà hàng..." 
                                   value="@search"
                                   style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: white; border-radius: 15px; padding: 18px 20px; font-size: 15px; backdrop-filter: blur(10px); transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                        </div>

                        <!-- Modern Price Filter -->
                        <div class="mb-4">
                            <label class="form-label modern-label" style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 15px; font-size: 14px; display: flex; align-items: center;">
                                <i class="bi bi-currency-dollar me-2" style="color: #ffd700;"></i>Giá trung bình/người (VNĐ)
                            </label>
                            <div class="price-range-container">
                                <div class="mb-3">
                                    <input type="number" name="minPrice" class="form-control modern-input" placeholder="Từ" 
                                           value="@minPrice" 
                                           style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: white; border-radius: 15px; padding: 15px 18px; font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                </div>
                                <div class="mb-3">
                                    <input type="number" name="maxPrice" class="form-control modern-input" placeholder="Đến" 
                                           value="@maxPrice"
                                           style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: white; border-radius: 15px; padding: 15px 18px; font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn modern-filter-btn w-100 mb-3" 
                                style="background: linear-gradient(135deg, #ff8e53, #ff6b9d); color: white; border: none; border-radius: 15px; padding: 18px; font-weight: 600; font-size: 16px; box-shadow: 0 10px 30px rgba(255,142,83,0.3); transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                            <i class="bi bi-funnel me-2"></i>Áp dụng bộ lọc
                        </button>
                    </form>

                    <!-- Clear Filter -->
                    <a href="@Url.Action("Index", "Restaurant")" class="btn clear-filter-btn w-100" 
                       style="background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.15); border-radius: 15px; padding: 15px; font-weight: 500; text-decoration: none; display: block; text-align: center; transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                        <i class="bi bi-x-circle me-2"></i>Xóa bộ lọc
                    </a>
                </div>
            </div>

            <!-- Main Content - Modern Restaurants Grid -->
            <div class="col-lg-9">
                <!-- Modern Header -->
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="mb-2" style="font-size: 2.8rem; font-weight: 800; color: white; letter-spacing: -1px; font-family: 'Plus Jakarta Sans', sans-serif;">
                            Nhà Hàng & Ẩm Thực
                        </h2>
                        <p class="text-muted mb-0" style="color: rgba(255,255,255,0.7); font-size: 18px; font-weight: 400; font-family: 'Plus Jakarta Sans', sans-serif;">
                            <i class="bi bi-cup-hot me-2" style="color: #ff8e53;"></i>Tìm thấy <span style="color: #ff8e53; font-weight: 600;">@totalCount</span> nhà hàng tuyệt vời
                        </p>
                    </div>
                </div>

                <!-- Modern Restaurants Grid -->
                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var restaurant in Model)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="restaurant-card modern-restaurant-card" 
                                     style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; overflow: hidden; cursor: pointer; transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); height: 100%; display: flex; flex-direction: column; box-shadow: 0 15px 35px rgba(0,0,0,0.3);"
                                     onclick="window.location.href='@Url.Action("Detail", "Restaurant", new { id = restaurant.Id })'">
                                    
                                    <!-- Modern Image/Icon Section -->
                                    <div class="position-relative restaurant-image-container" style="height: 260px; overflow: hidden; flex-shrink: 0;">
                                        @if (!string.IsNullOrEmpty(restaurant.ImageUrl))
                                        {
                                            <img src="@restaurant.ImageUrl" alt="@restaurant.Name" 
                                                 style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;">
                                        }
                                        else
                                        {
                                            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #ff8e53 0%, #ff6b9d 50%, #c44569 100%); display: flex; align-items: center; justify-content: center; position: relative;">
                                                <div class="restaurant-icon-container" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; border: 1px solid rgba(255,255,255,0.2);">
                                                    <i class="bi bi-egg-fried" style="font-size: 48px; color: rgba(255,255,255,0.9);"></i>
                                                </div>
                                                <!-- Floating particles effect -->
                                                <div class="floating-particles">
                                                    <div class="particle" style="position: absolute; width: 4px; height: 4px; background: rgba(255,255,255,0.6); border-radius: 50%; top: 20%; left: 15%; animation: float 3s ease-in-out infinite;"></div>
                                                    <div class="particle" style="position: absolute; width: 6px; height: 6px; background: rgba(255,255,255,0.4); border-radius: 50%; top: 60%; right: 20%; animation: float 4s ease-in-out infinite 1s;"></div>
                                                    <div class="particle" style="position: absolute; width: 3px; height: 3px; background: rgba(255,255,255,0.7); border-radius: 50%; bottom: 30%; left: 70%; animation: float 5s ease-in-out infinite 2s;"></div>
                                                </div>
                                            </div>
                                        }
                                        
                                        <!-- Modern Price Badge -->
                                        <div class="position-absolute top-0 end-0 m-4">
                                            <div class="price-badge" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(15px); color: #ffd700; padding: 12px 18px; border-radius: 20px; font-size: 14px; font-weight: 700; border: 1px solid rgba(255,215,0,0.3); font-family: 'Plus Jakarta Sans', sans-serif;">
                                                @string.Format("{0:N0}", restaurant.AveragePricePerPerson)đ<span style="font-size: 11px; opacity: 0.8; font-weight: 500;">/người</span>
                                            </div>
                                        </div>
                                        
                                        <!-- Favorite Button -->
                                        <div class="position-absolute bottom-0 end-0 m-4">
                                            <button class="btn favorite-btn" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border: none; border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 5px 15px rgba(0,0,0,0.2);">
                                                <i class="bi bi-heart" style="color: #ff8e53; font-size: 18px;"></i>
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <!-- Modern Content -->
                                    <div class="p-4" style="flex-grow: 1; display: flex; flex-direction: column; font-family: 'Plus Jakarta Sans', sans-serif;">
                                        <!-- Tourist Place Badge -->
                                        @if (restaurant.TouristPlace != null)
                                        {
                                            <div class="mb-3">
                                                <span class="location-badge" style="background: rgba(255,142,83,0.15); color: #ff8e53; padding: 8px 15px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1px solid rgba(255,142,83,0.3); display: inline-flex; align-items: center;">
                                                    <i class="bi bi-geo-alt me-2"></i>@restaurant.TouristPlace.Name
                                                </span>
                                            </div>
                                        }
                                        
                                        <!-- Restaurant Name -->
                                        <h4 class="mb-3" style="font-size: 22px; font-weight: 700; color: white; line-height: 1.3; flex-grow: 0; font-family: 'Plus Jakarta Sans', sans-serif;">
                                            @restaurant.Name
                                        </h4>
                                        
                                        <!-- Address -->
                                        @if (!string.IsNullOrEmpty(restaurant.Address))
                                        {
                                            <p class="mb-3" style="color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.6; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                <i class="bi bi-geo-alt-fill me-2" style="color: #ff8e53;"></i>@restaurant.Address
                                            </p>
                                        }
                                        
                                        <!-- Phone -->
                                        @if (!string.IsNullOrEmpty(restaurant.Phone))
                                        {
                                            <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">
                                                <i class="bi bi-telephone-fill me-2" style="color: #ff8e53;"></i>@restaurant.Phone
                                            </p>
                                        }
                                        
                                        <!-- Modern Footer -->
                                        <div class="d-flex align-items-center justify-content-between mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                            <div class="view-details" style="color: #ff8e53; font-weight: 600; font-size: 14px; transition: all 0.3s ease; display: flex; align-items: center;">
                                                Xem chi tiết <i class="bi bi-arrow-right ms-2"></i>
                                            </div>
                                            <div class="rating" style="color: #ffd700; font-size: 14px; display: flex; align-items: center;">
                                                <i class="bi bi-star-fill me-1"></i>4.7
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Modern Empty State -->
                    <div class="text-center py-5">
                        <div class="empty-state glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border-radius: 25px; padding: 80px 50px; border: 1px solid rgba(255,255,255,0.1); max-width: 500px; margin: 0 auto;">
                            <div class="empty-icon mb-4" style="background: linear-gradient(135deg, #ff8e53, #ff6b9d); width: 80px; height: 80px; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                <i class="bi bi-egg-fried" style="font-size: 40px; color: white;"></i>
                            </div>
                            <h3 class="mt-3 mb-3" style="color: white; font-size: 28px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif;">Không tìm thấy nhà hàng</h3>
                            <p class="text-muted mb-4" style="color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.6; font-family: 'Plus Jakarta Sans', sans-serif;">
                                Hãy thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác để khám phá những nhà hàng tuyệt vời
                            </p>
                            <a href="@Url.Action("Index", "Restaurant")" class="btn mt-3" 
                               style="background: linear-gradient(135deg, #ff8e53, #ff6b9d); color: white; border: none; border-radius: 20px; padding: 18px 45px; font-weight: 600; text-decoration: none; font-size: 16px; box-shadow: 0 10px 30px rgba(255,142,83,0.4); font-family: 'Plus Jakarta Sans', sans-serif;">
                                <i class="bi bi-arrow-clockwise me-2"></i>Xem tất cả nhà hàng
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    /* Modern CSS Variables */
    :root {
        --primary-orange: #ff8e53;
        --primary-pink: #ff6b9d;
        --primary-pink-dark: #c44569;
        --accent-gold: #ffd700;
        --glass-bg: rgba(255,255,255,0.05);
        --glass-border: rgba(255,255,255,0.1);
        --text-primary: #ffffff;
        --text-secondary: rgba(255,255,255,0.8);
        --text-muted: rgba(255,255,255,0.6);
        --shadow-light: 0 10px 30px rgba(0,0,0,0.3);
        --shadow-heavy: 0 25px 50px rgba(0,0,0,0.4);
        --blur-light: blur(15px);
        --blur-heavy: blur(25px);
        --radius-sm: 15px;
        --radius-md: 20px;
        --radius-lg: 25px;
        --transition-smooth: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Neon Glow Background Effects */
    .neon-glow-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0.6;
        animation: float 8s ease-in-out infinite;
    }

    .glow-orb-1 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,142,83,0.4) 0%, transparent 70%);
        top: 10%;
        left: 10%;
        animation-delay: 0s;
    }

    .glow-orb-2 {
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(255,107,157,0.3) 0%, transparent 70%);
        top: 60%;
        right: 15%;
        animation-delay: 2s;
    }

    .glow-orb-3 {
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(255,215,0,0.2) 0%, transparent 70%);
        bottom: 20%;
        left: 50%;
        animation-delay: 4s;
    }

    .section-glow-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .section-glow-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.3;
        animation: float 12s ease-in-out infinite;
    }

    .section-glow-1 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,142,83,0.2) 0%, transparent 70%);
        top: 20%;
        right: 10%;
        animation-delay: 1s;
    }

    .section-glow-2 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,107,157,0.15) 0%, transparent 70%);
        bottom: 30%;
        left: 20%;
        animation-delay: 3s;
    }

    .section-glow-3 {
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(255,215,0,0.1) 0%, transparent 70%);
        top: 50%;
        left: 60%;
        animation-delay: 5s;
    }

    /* Hero Section Animations */
    .hero-title {
        animation: fadeInUp 1s ease-out;
    }
    
    .hero-subtitle {
        animation: fadeInUp 1s ease-out 0.2s both;
    }
    
    .hero-search-box {
        animation: fadeInUp 1s ease-out 0.4s both;
    }
    
    .hero-search-btn:hover {
        background: linear-gradient(135deg, var(--primary-pink), var(--primary-orange)) !important;
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(255,142,83,0.5) !important;
    }

    .modern-search:focus {
        box-shadow: 0 0 0 4px rgba(255,142,83,0.2) !important;
        transform: scale(1.02);
    }

    /* Glassmorphism Panel Effects */
    .glassmorphism-panel {
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        transition: var(--transition-smooth);
        position: relative;
    }

    .glassmorphism-panel::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(255,142,83,0.05), rgba(255,107,157,0.03));
        border-radius: inherit;
        opacity: 0;
        transition: opacity var(--transition-smooth);
        pointer-events: none;
    }

    .glassmorphism-panel:hover::before {
        opacity: 1;
    }

    .glassmorphism-panel:hover {
        background: rgba(255,255,255,0.08) !important;
        border-color: rgba(255,255,255,0.15) !important;
        transform: translateY(-2px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5) !important;
    }

    /* Modern Input Styles */
    .modern-input {
        transition: var(--transition-smooth);
        backdrop-filter: var(--blur-light);
        -webkit-backdrop-filter: var(--blur-light);
    }

    .modern-input:focus {
        border-color: rgba(255,142,83,0.5) !important;
        box-shadow: 0 0 0 4px rgba(255,142,83,0.15) !important;
        background: rgba(255,255,255,0.12) !important;
        transform: scale(1.02);
    }

    .modern-input::placeholder {
        color: rgba(255,255,255,0.5);
        font-weight: 400;
    }

    /* Modern Button Effects */
    .modern-filter-btn:hover {
        background: linear-gradient(135deg, var(--primary-pink), var(--primary-orange)) !important;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(255,142,83,0.4) !important;
    }

    .clear-filter-btn:hover {
        background: rgba(255,255,255,0.12) !important;
        border-color: rgba(255,255,255,0.2) !important;
        transform: translateY(-2px);
    }

    /* Modern Restaurant Card Styles */
    .modern-restaurant-card {
        transition: var(--transition-smooth);
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        position: relative;
        overflow: hidden;
    }

    .modern-restaurant-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, transparent, rgba(255,142,83,0.05));
        opacity: 0;
        transition: opacity var(--transition-smooth);
        pointer-events: none;
        border-radius: inherit;
    }

    .modern-restaurant-card:hover {
        transform: translateY(-15px) scale(1.02);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.08) !important;
    }

    .modern-restaurant-card:hover::before {
        opacity: 1;
    }

    .modern-restaurant-card:hover .restaurant-image-container img {
        transform: scale(1.1);
    }

    .modern-restaurant-card:hover .view-details {
        transform: translateX(8px);
        color: #ff7a47 !important;
    }

    .modern-restaurant-card:hover .favorite-btn {
        background: rgba(255,142,83,0.9) !important;
        transform: scale(1.1);
    }

    .modern-restaurant-card:hover .favorite-btn i {
        color: white !important;
    }

    .modern-restaurant-card:hover .price-badge {
        background: rgba(255,215,0,0.2) !important;
        border-color: rgba(255,215,0,0.5) !important;
        transform: scale(1.05);
    }

    /* Floating Particles Animation */
    .particle {
        animation: float 3s ease-in-out infinite;
    }

    /* Filter Sidebar Scrollbar */
    .filter-sidebar {
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    .filter-sidebar::-webkit-scrollbar {
        width: 6px;
    }

    .filter-sidebar::-webkit-scrollbar-track {
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
    }

    .filter-sidebar::-webkit-scrollbar-thumb {
        background: rgba(255,142,83,0.5);
        border-radius: 3px;
    }

    .filter-sidebar::-webkit-scrollbar-thumb:hover {
        background: rgba(255,142,83,0.7);
    }

    /* Floating Animation */
    .floating-element {
        animation: float 6s ease-in-out infinite;
    }

    /* Modern Label Styles */
    .modern-label {
        font-family: 'Plus Jakarta Sans', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px !important;
    }

    /* Neon Glow Effects for Cards */
    .modern-restaurant-card:hover {
        box-shadow: 
            0 30px 60px rgba(0,0,0,0.5),
            0 0 30px rgba(255,142,83,0.2),
            0 0 0 1px rgba(255,255,255,0.1) !important;
    }

    /* Enhanced Empty State */
    .empty-state:hover {
        transform: translateY(-5px);
        box-shadow: 
            0 35px 70px rgba(0,0,0,0.6),
            0 0 40px rgba(255,142,83,0.15) !important;
    }
</style>

@{
    string restaurantKeyframes = @"
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-8px) rotate(1deg); }
            66% { transform: translateY(-4px) rotate(-1deg); }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes glow {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }
    ";
    
    string restaurantResponsiveCSS = @"
        @media (max-width: 992px) {
            .filter-sidebar {
                position: relative !important;
                top: 0 !important;
                margin-bottom: 30px;
            }

            #restaurants-section {
                padding: 20px 0;
            }

            .hero-section {
                height: 50vh !important;
                margin-top: 60px !important;
            }

            .hero-title {
                font-size: 2.5rem !important;
            }

            .hero-subtitle {
                font-size: 1.1rem !important;
            }

            .hero-search-box {
                padding: 20px !important;
            }

            .modern-restaurant-card {
                margin-bottom: 20px;
            }

            .glow-orb, .section-glow-orb {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .hero-section {
                height: 40vh !important;
            }

            .hero-title {
                font-size: 2rem !important;
            }

            .hero-search-box form {
                flex-direction: column !important;
                gap: 15px !important;
            }

            .hero-search-btn {
                width: 100% !important;
            }

            .glassmorphism-panel {
                padding: 25px !important;
            }
        }
    ";
}

<style>
    @Html.Raw(restaurantKeyframes)
    @Html.Raw(restaurantResponsiveCSS)
</style>




