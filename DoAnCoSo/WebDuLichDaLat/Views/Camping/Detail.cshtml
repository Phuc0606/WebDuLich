@model WebDuLichDaLat.Models.CampingSite
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_LayoutNoFooter.cshtml";
}

<!-- Main Content Section -->
<section id="camping-detail-section" style="background-color: #1a1a1a; color: white; min-height: 100vh; padding: 80px 0 40px 0; margin-top: 0;">
    <div class="container">
        <!-- Back Button -->
        <div class="mb-4">
            <a href="@Url.Action("Index", "Camping")" class="btn back-btn" 
               style="background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); color: white; border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 12px 24px; text-decoration: none; font-weight: 500; transition: all 0.3s ease;">
                <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
            </a>
        </div>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Hero Image - Full Width -->
                <div class="mb-5 hero-image-container">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="hero-image-full">
                            <div class="position-relative hero-parallax" style="height: 60vh; border-radius: var(--radius-xl); overflow: hidden; box-shadow: var(--shadow-heavy); margin-bottom: 30px;">
                                <img src="@Model.ImageUrl" alt="@Model.Name" 
                                     style="width: 100%; height: 100%; object-fit: cover;">
                                <!-- Overlay with gradient -->
                                <div class="position-absolute bottom-0 start-0 end-0" style="background: linear-gradient(transparent, rgba(0,0,0,0.8)); height: 200px; display: flex; align-items: end; padding: 40px;">
                                    <div class="container">
                                        <div class="floating-element">
                                            <h1 class="mb-3" style="font-size: 3.5rem; font-weight: 800; color: var(--text-primary); text-shadow: 2px 2px 4px rgba(0,0,0,0.7); letter-spacing: -1px;">
                                                @Model.Name
                                            </h1>
                                            @if (Model.Location != null)
                                            {
                                                <p class="mb-0" style="font-size: 1.3rem; color: var(--text-secondary); text-shadow: 1px 1px 2px rgba(0,0,0,0.5); display: flex; align-items: center;">
                                                    <i class="bi bi-geo-alt me-3" style="color: var(--primary-color); font-size: 1.5rem;"></i>@Model.Location.Name
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <!-- Floating Action Buttons -->
                                <div class="position-absolute top-0 end-0 m-4">
                                    <div class="d-flex flex-column gap-3">
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: var(--blur-light); border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast); box-shadow: var(--shadow-light);">
                                            <i class="bi bi-heart" style="color: var(--secondary-color); font-size: 20px;"></i>
                                        </button>
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: var(--blur-light); border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast); box-shadow: var(--shadow-light); animation-delay: 0.2s;">
                                            <i class="bi bi-share" style="color: var(--primary-color); font-size: 20px;"></i>
                                        </button>
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: var(--blur-light); border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; transition: var(--transition-fast); box-shadow: var(--shadow-light); animation-delay: 0.4s;">
                                            <i class="bi bi-camera" style="color: var(--accent-color); font-size: 20px;"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="hero-image-full">
                            <div class="position-relative hero-parallax" style="height: 60vh; background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-color) 100%); border-radius: var(--radius-xl); display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-heavy); margin-bottom: 30px;">
                                <div class="text-center floating-element">
                                    <i class="bi bi-tent" style="font-size: 120px; color: rgba(255,255,255,0.4); margin-bottom: 30px;"></i>
                                    <h1 class="mb-3" style="font-size: 3.5rem; font-weight: 800; color: var(--text-primary);">
                                        @Model.Name
                                    </h1>
                                    @if (Model.Location != null)
                                    {
                                        <p class="mb-0" style="font-size: 1.3rem; color: var(--text-secondary);">
                                            <i class="bi bi-geo-alt me-3"></i>@Model.Location.Name
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Gallery Grid -->
                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <div class="mb-5">
                        <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white;">
                            <i class="bi bi-images me-2" style="color: #ff6b9d;"></i>Thư viện ảnh
                        </h3>
                        <div class="gallery-grid">
                            @for (int i = 0; i < Math.Min(Model.ImageUrls.Count(), 6); i++)
                            {
                                var imgUrl = Model.ImageUrls.ElementAt(i);
                                <div class="gallery-item @(i == 0 ? "gallery-main" : i < 3 ? "gallery-secondary" : "gallery-tertiary")" 
                                     style="border-radius: 15px; overflow: hidden; cursor: pointer; transition: all 0.3s ease; position: relative;">
                                    <img src="@imgUrl" alt="@Model.Name" 
                                         style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;">
                                    @if (i == 5 && Model.ImageUrls.Count() > 6)
                                    {
                                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" 
                                             style="background: rgba(0,0,0,0.7); backdrop-filter: blur(5px);">
                                            <span style="color: white; font-size: 18px; font-weight: 600;">
                                                +@(Model.ImageUrls.Count() - 5) ảnh
                                            </span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-5 description-card" style="background: rgba(42,42,42,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                        <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white;">
                            <i class="bi bi-info-circle me-2" style="color: #6bc46b;"></i>Mô tả chi tiết
                        </h3>
                        <p style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; margin: 0;">
                            @Model.Description
                        </p>
                    </div>
                }

                <!-- Amenities Section -->
                @if (!string.IsNullOrEmpty(Model.Amenities))
                {
                    <div class="mb-5 amenities-card" style="background: rgba(42,42,42,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                        <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white;">
                            <i class="bi bi-star-fill me-2" style="color: #ffd700;"></i>Tiện ích & Dịch vụ
                        </h3>
                        @{
                            var amenitiesList = Model.Amenities.Split(',', StringSplitOptions.RemoveEmptyEntries);
                            var amenityIcons = new Dictionary<string, string>
                            {
                                {"wifi", "bi-wifi"}, {"parking", "bi-car-front"}, {"restaurant", "bi-cup-hot"},
                                {"pool", "bi-water"}, {"gym", "bi-heart-pulse"}, {"spa", "bi-flower1"},
                                {"beach", "bi-water"}, {"mountain", "bi-mountain"}, {"forest", "bi-tree"},
                                {"toilet", "bi-house"}, {"shower", "bi-droplet"}, {"kitchen", "bi-cup-straw"}
                            };
                        }
                        <div class="row g-3">
                            @foreach (var amenity in amenitiesList)
                            {
                                var cleanAmenity = amenity.Trim().ToLower();
                                var icon = amenityIcons.FirstOrDefault(x => cleanAmenity.Contains(x.Key)).Value ?? "bi-check-circle";
                                
                                <div class="col-md-6 col-lg-4">
                                    <div class="amenity-item" style="background: rgba(74,159,74,0.1); border: 1px solid rgba(74,159,74,0.3); border-radius: 12px; padding: 15px; transition: all 0.3s ease;">
                                        <i class="@icon me-3" style="color: #6bc46b; font-size: 20px;"></i>
                                        <span style="color: rgba(255,255,255,0.9); font-weight: 500;">@amenity.Trim()</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Sticky Booking Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-booking-card" style="position: sticky; top: 100px;">
                    <!-- Main Booking Card -->
                    <div class="booking-card glassmorphism-card" style="background: rgba(42,42,42,0.9); backdrop-filter: blur(30px); border: 1px solid rgba(255,255,255,0.15); border-radius: 25px; padding: 35px; box-shadow: 0 25px 50px rgba(0,0,0,0.4); margin-bottom: 20px;">
                        <!-- Price Section -->
                        <div class="price-section mb-4" style="text-align: center; padding: 25px; background: linear-gradient(135deg, rgba(74,159,74,0.15), rgba(107,196,107,0.1)); border-radius: 20px; border: 1px solid rgba(74,159,74,0.3);">
                            <div style="color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 8px; font-weight: 500;">Giá mỗi đêm từ</div>
                            <div class="price-display" style="font-size: 2.5rem; font-weight: 800; color: #6bc46b; margin-bottom: 5px;">
                                @string.Format("{0:N0}", Model.PricePerNight)<span style="font-size: 1.2rem; font-weight: 600; color: rgba(255,255,255,0.8);">đ</span>
                            </div>
                            <div style="color: rgba(255,255,255,0.6); font-size: 13px;">Chưa bao gồm thuế và phí</div>
                        </div>

                        <!-- Available Spots -->
                        @if (Model.AvailableSpots.HasValue)
                        {
                            <div class="spots-section mb-4" style="background: rgba(74,159,74,0.1); border: 1px solid rgba(74,159,74,0.3); border-radius: 15px; padding: 20px;">
                                <div class="d-flex align-items-center">
                                    <div class="spots-icon" style="background: rgba(74,159,74,0.2); border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                                        <i class="bi bi-tent" style="font-size: 24px; color: #6bc46b;"></i>
                                    </div>
                                    <div>
                                        <div style="color: rgba(255,255,255,0.7); font-size: 13px; margin-bottom: 2px;">Chỗ cắm trại có sẵn</div>
                                        <div style="font-size: 24px; font-weight: 700; color: white;">@Model.AvailableSpots <span style="font-size: 16px; font-weight: 500;">chỗ</span></div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Booking Form -->
                        <div class="booking-form mb-4">
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <label class="form-label" style="color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600;">Ngày nhận</label>
                                    <input type="date" class="form-control modern-input" style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 12px;">
                                </div>
                                <div class="col-6">
                                    <label class="form-label" style="color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600;">Ngày trả</label>
                                    <input type="date" class="form-control modern-input" style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 12px;">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" style="color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600;">Số người</label>
                                <select class="form-control modern-input" style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 12px;">
                                    <option value="1">1 người</option>
                                    <option value="2">2 người</option>
                                    <option value="3">3 người</option>
                                    <option value="4">4 người</option>
                                    <option value="5">5+ người</option>
                                </select>
                            </div>
                        </div>

                        <!-- Book Button -->
                        <button class="btn book-now-btn w-100 mb-3" 
                                style="background: linear-gradient(135deg, #6bc46b, #4a9f4a); color: white; border: none; border-radius: 15px; padding: 18px; font-size: 18px; font-weight: 700; box-shadow: 0 10px 30px rgba(107,196,107,0.4); transition: all 0.3s ease;">
                            <i class="bi bi-calendar-check me-2"></i>Đặt chỗ ngay
                        </button>

                        <div class="text-center" style="color: rgba(255,255,255,0.6); font-size: 12px;">
                            Bạn sẽ chưa bị tính phí
                        </div>
                    </div>

                    <!-- Contact Card -->
                    <div class="contact-card glassmorphism-card" style="background: rgba(42,42,42,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.3);">
                        <h4 class="mb-3" style="font-size: 18px; font-weight: 700; color: white;">
                            <i class="bi bi-headset me-2" style="color: #ff6b9d;"></i>Thông tin liên hệ
                        </h4>

                        <!-- Location -->
                        @if (Model.Location != null || !string.IsNullOrEmpty(Model.Address))
                        {
                            <div class="contact-item mb-3" style="padding: 15px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                                <div class="d-flex align-items-start">
                                    <i class="bi bi-geo-alt-fill me-3" style="color: #6bc46b; font-size: 18px; margin-top: 2px;"></i>
                                    <div>
                                        <div style="font-weight: 600; color: white; margin-bottom: 5px;">Địa chỉ</div>
                                        @if (Model.Location != null)
                                        {
                                            <div style="color: rgba(255,255,255,0.8); font-size: 15px; margin-bottom: 3px;">@Model.Location.Name</div>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Address))
                                        {
                                            <div style="color: rgba(255,255,255,0.7); font-size: 14px;">@Model.Address</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Phone -->
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <div class="contact-item mb-3" style="padding: 15px; background: rgba(255,255,255,0.05); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-telephone-fill me-3" style="color: #6bc46b; font-size: 18px;"></i>
                                    <div>
                                        <div style="font-weight: 600; color: white; margin-bottom: 5px;">Hotline</div>
                                        <a href="tel:@Model.Phone" style="color: #6bc46b; text-decoration: none; font-size: 16px; font-weight: 600;">
                                            @Model.Phone
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Quick Actions -->
                        <div class="quick-actions mt-4">
                            <div class="row g-2">
                                <div class="col-6">
                                    <button class="btn w-100" style="background: rgba(255,107,157,0.1); color: #ff6b9d; border: 1px solid rgba(255,107,157,0.3); border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 600;">
                                        <i class="bi bi-chat-dots me-1"></i>Chat
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button class="btn w-100" style="background: rgba(74,159,74,0.1); color: #6bc46b; border: 1px solid rgba(74,159,74,0.3); border-radius: 12px; padding: 12px; font-size: 14px; font-weight: 600;">
                                        <i class="bi bi-share me-1"></i>Chia sẻ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* CSS Variables for Easy Theme Management */
    :root {
        --primary-color: #6bc46b;
        --primary-dark: #4a9f4a;
        --secondary-color: #ff6b9d;
        --secondary-dark: #c44569;
        --accent-color: #ffd700;
        --bg-primary: #1a1a1a;
        --bg-secondary: #2a2a2a;
        --bg-card: rgba(42,42,42,0.8);
        --text-primary: #ffffff;
        --text-secondary: rgba(255,255,255,0.8);
        --text-muted: rgba(255,255,255,0.6);
        --border-color: rgba(255,255,255,0.1);
        --border-light: rgba(255,255,255,0.2);
        --shadow-light: 0 10px 30px rgba(0,0,0,0.3);
        --shadow-heavy: 0 25px 50px rgba(0,0,0,0.4);
        --blur-light: blur(10px);
        --blur-heavy: blur(20px);
        --blur-ultra: blur(30px);
        --radius-sm: 12px;
        --radius-md: 15px;
        --radius-lg: 20px;
        --radius-xl: 25px;
        --transition-fast: 0.3s ease;
        --transition-smooth: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Glassmorphism Effects */
    .glassmorphism-card {
        backdrop-filter: var(--blur-ultra);
        -webkit-backdrop-filter: var(--blur-ultra);
        border: 1px solid rgba(255,255,255,0.15);
        box-shadow: var(--shadow-heavy);
    }

    /* Back Button */
    .back-btn:hover {
        background: rgba(255,255,255,0.2) !important;
        border-color: var(--border-light) !important;
        transform: translateY(-2px);
    }

    /* Hero Image */
    .hero-image-container {
        animation: fadeInUp 0.8s ease-out;
    }

    /* Full-width Hero Image */
    .hero-image-full {
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        width: 100vw;
        position: relative;
    }

    /* Gallery Grid */
    .gallery-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        grid-template-rows: 200px 200px;
        gap: var(--radius-md);
        animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .gallery-main {
        grid-row: span 2;
        height: 415px !important;
    }

    .gallery-secondary {
        height: 200px;
    }

    .gallery-tertiary {
        height: 200px;
    }

    .gallery-item:hover {
        transform: scale(1.02);
        box-shadow: var(--shadow-light);
    }

    .gallery-item:hover img {
        transform: scale(1.05);
    }

    /* Cards Animation */
    .description-card, .amenities-card {
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    /* Amenity Items */
    .amenity-item:hover {
        background: rgba(74,159,74,0.2) !important;
        border-color: rgba(74,159,74,0.5) !important;
        transform: translateY(-2px);
    }

    /* Sticky Booking Card */
    .sticky-booking-card {
        animation: fadeInUp 0.8s ease-out 0.6s both;
    }

    .booking-card {
        transition: var(--transition-fast);
        position: relative;
        overflow: hidden;
    }

    .booking-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, transparent, rgba(107,196,107,0.05));
        opacity: 0;
        transition: opacity var(--transition-fast);
        border-radius: var(--radius-xl);
        pointer-events: none;
    }

    .booking-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5) !important;
    }

    .booking-card:hover::before {
        opacity: 1;
    }

    /* Price Display Animation */
    .price-display {
        animation: pulse 2s infinite;
        position: relative;
    }

    .price-display::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120%;
        height: 120%;
        background: radial-gradient(circle, rgba(107,196,107,0.1) 0%, transparent 70%);
        border-radius: 50%;
        animation: ripple 3s infinite;
        pointer-events: none;
    }

    /* Modern Input Styles */
    .modern-input {
        transition: var(--transition-fast);
        backdrop-filter: var(--blur-light);
        -webkit-backdrop-filter: var(--blur-light);
    }

    .modern-input:focus {
        border-color: rgba(107,196,107,0.5) !important;
        box-shadow: 0 0 0 3px rgba(107,196,107,0.1) !important;
        background: rgba(26,26,26,0.9) !important;
    }

    /* Book Now Button */
    .book-now-btn {
        position: relative;
        overflow: hidden;
    }

    .book-now-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }

    .book-now-btn:hover::before {
        left: 100%;
    }

    .book-now-btn:hover {
        background: linear-gradient(135deg, var(--primary-dark), var(--primary-color)) !important;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(107,196,107,0.5) !important;
    }

    /* Contact Items */
    .contact-item {
        transition: var(--transition-fast);
        position: relative;
        overflow: hidden;
    }

    .contact-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(107,196,107,0.1), transparent);
        transition: left 0.5s;
    }

    .contact-item:hover::before {
        left: 100%;
    }

    .contact-item:hover {
        background: rgba(255,255,255,0.1) !important;
        border-color: var(--border-light) !important;
        transform: translateX(5px);
    }

    /* Quick Actions */
    .quick-actions .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    /* Advanced Parallax Effect for Hero */
    .hero-parallax {
        transform-style: preserve-3d;
        transition: transform 0.1s ease-out;
    }

    /* Floating Elements */
    .floating-element {
        animation: float 6s ease-in-out infinite;
    }

    .floating-element:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3) !important;
    }
</style>

@{
    string detailKeyframes = @"
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes ripple {
            0% { transform: translate(-50%, -50%) scale(0.8); opacity: 1; }
            100% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes countUp {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
    ";
    
    string detailResponsiveCSS = @"
        @media (max-width: 992px) {
            .sticky-booking-card {
                position: relative !important;
                top: 0 !important;
                margin-top: 30px;
            }

            #camping-detail-section {
                padding: 20px 0;
            }

            .gallery-grid {
                grid-template-columns: 1fr 1fr;
                grid-template-rows: 200px 150px 150px;
            }

            .gallery-main {
                grid-column: span 2;
                grid-row: span 1;
                height: 200px !important;
            }

            .hero-image-container .position-relative {
                height: 300px !important;
            }

            .hero-image-container h1 {
                font-size: 2rem !important;
            }

            .price-display {
                font-size: 2rem !important;
            }
        }

        @media (max-width: 768px) {
            .gallery-grid {
                grid-template-columns: 1fr;
                grid-template-rows: repeat(6, 150px);
            }

            .gallery-main {
                grid-column: span 1;
                height: 150px !important;
            }

            .booking-card {
                padding: 25px !important;
            }

            .contact-card {
                padding: 20px !important;
            }

            .amenities-card .row .col-md-6 {
                margin-bottom: 15px;
            }
        }
    ";
}

<style>
    @Html.Raw(detailKeyframes)
    @Html.Raw(detailResponsiveCSS)
</style>

<script>
    // Advanced Parallax Effect
    document.addEventListener('DOMContentLoaded', function() {
        const heroParallax = document.querySelector('.hero-parallax');
        const floatingElements = document.querySelectorAll('.floating-element');
        
        if (heroParallax) {
            window.addEventListener('scroll', function() {
                const scrolled = window.pageYOffset;
                const rate = scrolled * -0.5;
                heroParallax.style.transform = `translateY(${rate}px)`;
            });
        }

        // Mouse move parallax effect
        document.addEventListener('mousemove', function(e) {
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;
            
            floatingElements.forEach((element, index) => {
                const speed = (index + 1) * 0.5;
                const x = (mouseX - 0.5) * speed;
                const y = (mouseY - 0.5) * speed;
                element.style.transform = `translate(${x}px, ${y}px)`;
            });
        });

        // Smooth scroll for booking card
        const bookingCard = document.querySelector('.booking-card');
        if (bookingCard) {
            window.addEventListener('scroll', function() {
                const scrolled = window.pageYOffset;
                const cardTop = bookingCard.offsetTop;
                const windowHeight = window.innerHeight;
                
                if (scrolled > cardTop - windowHeight + 100) {
                    bookingCard.style.transform = 'translateY(-10px)';
                    bookingCard.style.boxShadow = '0 35px 70px rgba(0,0,0,0.6)';
                } else {
                    bookingCard.style.transform = 'translateY(0)';
                    bookingCard.style.boxShadow = '0 25px 50px rgba(0,0,0,0.4)';
                }
            });
        }

        // Price animation on scroll
        const priceDisplay = document.querySelector('.price-display');
        if (priceDisplay) {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.animation = 'pulse 2s infinite, countUp 2s ease-out';
                    }
                });
            });
            observer.observe(priceDisplay);
        }

        // Amenity items stagger animation
        const amenityItems = document.querySelectorAll('.amenity-item');
        amenityItems.forEach((item, index) => {
            item.style.animationDelay = `${index * 0.1}s`;
            item.style.animation = 'fadeInUp 0.6s ease-out both';
        });
    });
</script>





















