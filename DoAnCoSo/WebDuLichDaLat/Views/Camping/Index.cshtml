@model IEnumerable<WebDuLichDaLat.Models.CampingSite>
@{
    ViewData["Title"] = "Danh sách khu cắm trại";
    Layout = "~/Views/Shared/_LayoutNoFooter.cshtml";
    var search = ViewBag.Search as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
}

<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80') center/cover; height: 100vh; display: flex; align-items: center; position: relative; margin-top: 0; padding-top: 80px;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="hero-title mb-4" style="font-size: 3.5rem; font-weight: 800; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); line-height: 1.2;">
                    Khám Phá Thiên Nhiên
                </h1>
                <p class="hero-subtitle mb-5" style="font-size: 1.3rem; color: rgba(255,255,255,0.9); text-shadow: 1px 1px 2px rgba(0,0,0,0.5); font-weight: 300;">
                    Tìm kiếm những khu cắm trại tuyệt vời nhất tại Đà Lạt
                </p>
                <div class="hero-search-box" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-radius: 20px; padding: 20px; max-width: 600px; margin: 0 auto; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
                    <form method="get" action="@Url.Action("Index", "Camping")" class="d-flex gap-3 align-items-center">
                        <div class="flex-grow-1">
                            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm khu cắm trại..." 
                                   value="@search"
                                   style="border: none; background: transparent; color: #333; font-size: 16px; padding: 15px 20px; border-radius: 15px; box-shadow: none;">
                        </div>
                        <button class="btn hero-search-btn" type="submit" style="background: linear-gradient(135deg, #ff6b9d, #c44569); color: white; border: none; border-radius: 15px; padding: 15px 30px; font-weight: 600; box-shadow: 0 5px 15px rgba(255,107,157,0.3);">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Content Section -->
<section id="camping-section" style="background-color: #1a1a1a; color: white; min-height: 100vh; padding: 60px 0 40px 0;">
    <div class="container-fluid px-4">
        <div class="row">
            <!-- Sidebar Filters -->
            <div class="col-lg-3 mb-4">
                <div class="filter-sidebar glassmorphism-card" style="background: rgba(42,42,42,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 30px; position: sticky; top: 100px; box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
                    <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white; display: flex; align-items: center;">
                        <i class="bi bi-funnel me-3" style="color: #ff6b9d;"></i>Bộ lọc
                    </h3>
                    
                    <!-- Search -->
                    <form method="get" action="@Url.Action("Index", "Camping")">
                        <div class="mb-4">
                            <label class="form-label" style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 10px;">
                                <i class="bi bi-search me-2"></i>Tìm kiếm
                            </label>
                            <div class="input-group">
                                <input type="text" name="search" class="form-control modern-input" placeholder="Nhập tên khu cắm trại..." 
                                       value="@search"
                                       style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 15px 20px; font-size: 15px; backdrop-filter: blur(10px);">
                            </div>
                        </div>

                        <!-- Price Filter -->
                        <div class="mb-4">
                            <label class="form-label" style="color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 15px; display: flex; align-items: center;">
                                <i class="bi bi-currency-dollar me-2" style="color: #ffd700;"></i>Khoảng giá (VNĐ/đêm)
                            </label>
                            <div class="price-range-container">
                                <div class="mb-3">
                                    <input type="number" name="minPrice" class="form-control modern-input" placeholder="Từ" 
                                           value="@minPrice" 
                                           style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 12px 16px; font-size: 14px;">
                                </div>
                                <div class="mb-3">
                                    <input type="number" name="maxPrice" class="form-control modern-input" placeholder="Đến" 
                                           value="@maxPrice"
                                           style="background: rgba(26,26,26,0.8); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 12px; padding: 12px 16px; font-size: 14px;">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn modern-btn w-100 mb-3" 
                                style="background: linear-gradient(135deg, #ff6b9d, #c44569); color: white; border: none; border-radius: 12px; padding: 15px; font-weight: 600; font-size: 16px; box-shadow: 0 8px 25px rgba(255,107,157,0.3); transition: all 0.3s ease;">
                            <i class="bi bi-funnel me-2"></i>Áp dụng bộ lọc
                        </button>
                    </form>

                    <!-- Clear Filter -->
                    <a href="@Url.Action("Index", "Camping")" class="btn clear-btn w-100" 
                       style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; padding: 12px; font-weight: 500; text-decoration: none; display: block; text-align: center; transition: all 0.3s ease;">
                        <i class="bi bi-x-circle me-2"></i>Xóa bộ lọc
                    </a>
                </div>
            </div>

            <!-- Main Content - Camping Sites Grid -->
            <div class="col-lg-9">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="mb-2" style="font-size: 2.5rem; font-weight: 800; color: white; letter-spacing: -0.5px;">
                            Khu Cắm Trại Đà Lạt
                        </h2>
                        <p class="text-muted mb-0" style="color: rgba(255,255,255,0.7); font-size: 18px; font-weight: 300;">
                            <i class="bi bi-geo-alt me-2" style="color: #ff6b9d;"></i>Tìm thấy <span style="color: #6bc46b; font-weight: 600;">@totalCount</span> khu cắm trại tuyệt vời
                        </p>
                    </div>
                </div>

                <!-- Camping Sites Grid -->
                @if (Model != null && Model.Any())
                {
                    <div class="row g-4">
                        @foreach (var camping in Model)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="camping-card modern-card" 
                                     style="background: rgba(42,42,42,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; overflow: hidden; cursor: pointer; transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); height: 100%; display: flex; flex-direction: column; box-shadow: 0 10px 30px rgba(0,0,0,0.3);"
                                     onclick="window.location.href='@Url.Action("Detail", "Camping", new { id = camping.Id })'">
                                    <!-- Image -->
                                    <div class="position-relative image-container" style="height: 240px; overflow: hidden; flex-shrink: 0;">
                                        @if (!string.IsNullOrEmpty(camping.ImageUrl))
                                        {
                                            <img src="@camping.ImageUrl" alt="@camping.Name" 
                                                 style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;">
                                        }
                                        else
                                        {
                                            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #4a9f4a 0%, #6bc46b 100%); display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-tent" style="font-size: 64px; color: rgba(255,255,255,0.4);"></i>
                                            </div>
                                        }
                                        
                                        <!-- Price Badge -->
                                        <div class="position-absolute top-0 end-0 m-3">
                                            <span class="price-badge" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); color: #ffd700; padding: 8px 16px; border-radius: 25px; font-size: 14px; font-weight: 700; border: 1px solid rgba(255,215,0,0.3);">
                                                @string.Format("{0:N0}", camping.PricePerNight)đ<span style="font-size: 11px; opacity: 0.8;">/đêm</span>
                                            </span>
                                        </div>
                                        
                                        <!-- Available Spots Badge -->
                                        @if (camping.AvailableSpots.HasValue)
                                        {
                                            <div class="position-absolute top-0 start-0 m-3">
                                                <span class="spots-badge" style="background: rgba(74,159,74,0.9); backdrop-filter: blur(10px); color: white; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1px solid rgba(74,159,74,0.5);">
                                                    <i class="bi bi-tent me-1"></i>@camping.AvailableSpots chỗ
                                                </span>
                                            </div>
                                        }
                                        
                                        <!-- Favorite Button -->
                                        <div class="position-absolute bottom-0 end-0 m-3">
                                            <button class="btn favorite-btn" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border: none; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;">
                                                <i class="bi bi-heart" style="color: #ff6b9d; font-size: 16px;"></i>
                                            </button>
                                        </div>
                                    </div>
                                    
                                    <!-- Content -->
                                    <div class="p-4" style="flex-grow: 1; display: flex; flex-direction: column;">
                                        <!-- Location Badge -->
                                        @if (camping.Location != null)
                                        {
                                            <div class="mb-3">
                                                <span class="location-badge" style="background: rgba(74,159,74,0.15); color: #6bc46b; padding: 6px 12px; border-radius: 15px; font-size: 12px; font-weight: 600; border: 1px solid rgba(74,159,74,0.3);">
                                                    <i class="bi bi-geo-alt me-1"></i>@camping.Location.Name
                                                </span>
                                            </div>
                                        }
                                        
                                        <!-- Name -->
                                        <h4 class="mb-3" style="font-size: 20px; font-weight: 700; color: white; line-height: 1.3; flex-grow: 0;">
                                            @camping.Name
                                        </h4>
                                        
                                        <!-- Address -->
                                        @if (!string.IsNullOrEmpty(camping.Address))
                                        {
                                            <p class="mb-3" style="color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.5; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                                <i class="bi bi-geo-alt-fill me-2" style="color: #6bc46b;"></i>@camping.Address
                                            </p>
                                        }
                                        
                                        <!-- Amenities as Badges -->
                                        @if (!string.IsNullOrEmpty(camping.Amenities))
                                        {
                                            <div class="amenities-container mb-3">
                                                @{
                                                    var amenitiesList = camping.Amenities.Split(',', StringSplitOptions.RemoveEmptyEntries).Take(3);
                                                }
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (var amenity in amenitiesList)
                                                    {
                                                        <span class="amenity-badge" style="background: rgba(255,107,157,0.15); color: #ff6b9d; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 500; border: 1px solid rgba(255,107,157,0.3);">
                                                            @amenity.Trim()
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        
                                        <!-- Contact Info -->
                                        @if (!string.IsNullOrEmpty(camping.Phone))
                                        {
                                            <p class="mb-3" style="color: rgba(255,255,255,0.6); font-size: 13px;">
                                                <i class="bi bi-telephone-fill me-2" style="color: #6bc46b;"></i>@camping.Phone
                                            </p>
                                        }
                                        
                                        <!-- View Details Button -->
                                        <div class="d-flex align-items-center justify-content-between mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                            <div class="view-details" style="color: #6bc46b; font-weight: 600; font-size: 14px; transition: all 0.3s ease;">
                                                Xem chi tiết <i class="bi bi-arrow-right ms-2"></i>
                                            </div>
                                            <div class="rating" style="color: #ffd700; font-size: 14px;">
                                                <i class="bi bi-star-fill me-1"></i>4.8
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Empty State -->
                    <div class="text-center py-5">
                        <div class="empty-state" style="background: rgba(42,42,42,0.5); backdrop-filter: blur(20px); border-radius: 20px; padding: 60px 40px; border: 1px solid rgba(255,255,255,0.1);">
                            <div class="mb-4">
                                <i class="bi bi-tent" style="font-size: 80px; color: rgba(255,255,255,0.3);"></i>
                            </div>
                            <h3 class="mt-3 mb-3" style="color: white; font-size: 28px; font-weight: 700;">Không tìm thấy khu cắm trại</h3>
                            <p class="text-muted mb-4" style="color: rgba(255,255,255,0.6); font-size: 16px; max-width: 400px; margin: 0 auto;">
                                Hãy thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác để khám phá những địa điểm tuyệt vời
                            </p>
                            <a href="@Url.Action("Index", "Camping")" class="btn mt-3" 
                               style="background: linear-gradient(135deg, #6bc46b, #4a9f4a); color: white; border: none; border-radius: 15px; padding: 15px 40px; font-weight: 600; text-decoration: none; font-size: 16px; box-shadow: 0 8px 25px rgba(107,196,107,0.3);">
                                <i class="bi bi-arrow-clockwise me-2"></i>Xem tất cả khu cắm trại
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    /* CSS Variables for Easy Theme Management */
    :root {
        --primary-color: #6bc46b;
        --primary-dark: #4a9f4a;
        --secondary-color: #ff6b9d;
        --secondary-dark: #c44569;
        --accent-color: #ffd700;
        --bg-primary: #1a1a1a;
        --bg-secondary: #2a2a2a;
        --bg-card: rgba(42,42,42,0.8);
        --text-primary: #ffffff;
        --text-secondary: rgba(255,255,255,0.8);
        --text-muted: rgba(255,255,255,0.6);
        --border-color: rgba(255,255,255,0.1);
        --border-light: rgba(255,255,255,0.2);
        --shadow-light: 0 10px 30px rgba(0,0,0,0.3);
        --shadow-heavy: 0 25px 50px rgba(0,0,0,0.4);
        --blur-light: blur(10px);
        --blur-heavy: blur(20px);
        --blur-ultra: blur(30px);
        --radius-sm: 12px;
        --radius-md: 15px;
        --radius-lg: 20px;
        --radius-xl: 25px;
        --transition-fast: 0.3s ease;
        --transition-smooth: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Hero Section Styles */
    .hero-section {
        position: relative;
        overflow: hidden;
    }
    
    .hero-title {
        animation: fadeInUp 1s ease-out;
    }
    
    .hero-subtitle {
        animation: fadeInUp 1s ease-out 0.2s both;
    }
    
    .hero-search-box {
        animation: fadeInUp 1s ease-out 0.4s both;
    }
    
    .hero-search-btn:hover {
        background: linear-gradient(135deg, var(--secondary-dark), var(--secondary-color)) !important;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255,107,157,0.4) !important;
    }

    /* Glassmorphism Effects */
    .glassmorphism-card {
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-heavy);
    }

    /* Modern Card Styles */
    .modern-card {
        transition: var(--transition-smooth);
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
    }

    .modern-card:hover {
        transform: translateY(-12px) scale(1.02);
        box-shadow: var(--shadow-heavy), 0 0 0 1px var(--border-color);
    }

    .modern-card:hover .image-container img {
        transform: scale(1.1);
    }

    .modern-card:hover .view-details {
        transform: translateX(8px);
        color: var(--primary-dark) !important;
    }

    .modern-card:hover .favorite-btn {
        background: rgba(255,107,157,0.9) !important;
    }

    .modern-card:hover .favorite-btn i {
        color: var(--text-primary) !important;
    }

    /* Input Styles */
    .modern-input {
        transition: var(--transition-fast);
        backdrop-filter: var(--blur-light);
        -webkit-backdrop-filter: var(--blur-light);
    }

    .modern-input:focus {
        border-color: rgba(255,107,157,0.5) !important;
        box-shadow: 0 0 0 3px rgba(255,107,157,0.1) !important;
        background: rgba(26,26,26,0.9) !important;
    }

    /* Button Styles */
    .modern-btn:hover {
        background: linear-gradient(135deg, var(--secondary-dark), var(--secondary-color)) !important;
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(255,107,157,0.4) !important;
    }

    .clear-btn:hover {
        background: rgba(255,255,255,0.2) !important;
        border-color: var(--border-light) !important;
        transform: translateY(-2px);
    }

    /* Badge Styles */
    .price-badge, .spots-badge, .location-badge, .amenity-badge {
        transition: var(--transition-fast);
    }

    .modern-card:hover .price-badge {
        background: rgba(255,215,0,0.2) !important;
        border-color: rgba(255,215,0,0.5) !important;
    }

    .modern-card:hover .spots-badge {
        background: var(--primary-color) !important;
        transform: scale(1.05);
    }

    /* Filter Sidebar */
    .filter-sidebar {
        max-height: calc(100vh - 120px);
        overflow-y: auto;
    }

    .filter-sidebar::-webkit-scrollbar {
        width: 6px;
    }

    .filter-sidebar::-webkit-scrollbar-track {
        background: var(--border-color);
        border-radius: 3px;
    }

    .filter-sidebar::-webkit-scrollbar-thumb {
        background: rgba(255,107,157,0.5);
        border-radius: 3px;
    }

    .filter-sidebar::-webkit-scrollbar-thumb:hover {
        background: rgba(255,107,157,0.7);
    }

    /* Advanced Hover Effects */
    .camping-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, transparent, rgba(107,196,107,0.1));
        opacity: 0;
        transition: opacity var(--transition-fast);
        border-radius: var(--radius-lg);
        pointer-events: none;
    }

    .camping-card:hover::before {
        opacity: 1;
    }

    /* Floating Animation for Cards */
    .modern-card:nth-child(odd) {
        animation: float 6s ease-in-out infinite;
    }

    .modern-card:nth-child(even) {
        animation: float 6s ease-in-out infinite 3s;
    }
</style>

@{
    string floatKeyframes = @"
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-5px); }
        }
    ";
    
    string fadeInUpKeyframes = @"
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    ";
    
    string responsiveCSS = @"
        @media (max-width: 992px) {
            .filter-sidebar {
                position: relative !important;
                top: 0 !important;
                margin-bottom: 30px;
            }

            #camping-section {
                padding: 20px 0;
            }

            .hero-section {
                height: 50vh !important;
                margin-top: 60px !important;
            }

            .hero-title {
                font-size: 2.5rem !important;
            }

            .hero-subtitle {
                font-size: 1.1rem !important;
            }

            .hero-search-box {
                padding: 15px !important;
            }

            .modern-card {
                margin-bottom: 20px;
            }
        }

        @media (max-width: 768px) {
            .hero-section {
                height: 40vh !important;
            }

            .hero-title {
                font-size: 2rem !important;
            }

            .hero-search-box form {
                flex-direction: column !important;
                gap: 15px !important;
            }

            .hero-search-btn {
                width: 100% !important;
            }
        }
    ";
}

<style>
    @Html.Raw(floatKeyframes)
    @Html.Raw(fadeInUpKeyframes)
    @Html.Raw(responsiveCSS)
</style>





















