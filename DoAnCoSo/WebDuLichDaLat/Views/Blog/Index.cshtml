@model IEnumerable<WebDuLichDaLat.Models.BlogPost>
@{
    ViewData["Title"] = "Tin tức";
    Layout = "~/Views/Shared/_LayoutNoFooter.cshtml";
}

<!-- Import Magazine Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Hero Section with Magazine Style -->
<section class="hero-section" style="background: linear-gradient(135deg, rgba(30,30,30,0.9), rgba(0,0,0,0.8)), linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2072&q=80') center/cover; height: 100vh; display: flex; align-items: center; position: relative; margin-top: 0; padding-top: 80px;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="hero-title mb-4" style="font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 800; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.7); line-height: 1.1; letter-spacing: -2px;">
                    Tạp Chí Du Lịch Đà Lạt
                </h1>
                <p class="hero-subtitle mb-5" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.4rem; color: rgba(255,255,255,0.9); text-shadow: 1px 1px 2px rgba(0,0,0,0.5); font-weight: 300; font-style: italic;">
                    Khám phá những câu chuyện đặc sắc từ thành phố ngàn hoa
                </p>
                <div class="hero-search-box" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.2); border-radius: 25px; padding: 25px; max-width: 600px; margin: 0 auto; box-shadow: 0 25px 50px rgba(0,0,0,0.3);">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="flex-grow-1">
                            <input type="text" class="form-control modern-search" placeholder="Tìm kiếm bài viết..." 
                                   style="border: none; background: rgba(255,255,255,0.9); color: #333; font-size: 16px; padding: 18px 25px; border-radius: 20px; box-shadow: none; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 500;">
                        </div>
                        <button class="btn hero-search-btn" type="button" style="background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; border: none; border-radius: 20px; padding: 18px 35px; font-weight: 600; box-shadow: 0 8px 25px rgba(30,60,114,0.4); font-family: 'Plus Jakarta Sans', sans-serif;">
                            <i class="bi bi-search me-2"></i>Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Magazine Spotlight Effects -->
    <div class="magazine-spotlight-bg">
        <div class="spotlight-orb spotlight-orb-1"></div>
        <div class="spotlight-orb spotlight-orb-2"></div>
        <div class="spotlight-orb spotlight-orb-3"></div>
    </div>
</section>

<!-- Main Content Section -->
<section id="blog-section" style="background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%); color: white; min-height: 100vh; padding: 60px 0 40px 0; font-family: 'Plus Jakarta Sans', sans-serif; position: relative; overflow: hidden;">
    <!-- Background Paper Texture -->
    <div class="paper-texture-bg">
        <div class="paper-grain paper-grain-1"></div>
        <div class="paper-grain paper-grain-2"></div>
        <div class="paper-grain paper-grain-3"></div>
    </div>
    
    <div class="container-fluid px-4">
        <!-- Admin Toolbar (Floating) -->
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-toolbar" style="position: fixed; top: 100px; right: 30px; z-index: 1000; background: rgba(30,60,114,0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 15px 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
                <a asp-area="Admin" asp-controller="Blog" asp-action="Index" 
                   class="btn admin-btn" 
                   style="background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; border: none; border-radius: 15px; padding: 12px 20px; font-weight: 600; text-decoration: none; font-size: 14px; display: flex; align-items: center; transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                    <i class="bi bi-gear me-2"></i>Quản lý Blog
                </a>
            </div>
        }

        <!-- Modern Header -->
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="mb-3" style="font-family: 'Playfair Display', serif; font-size: 3.2rem; font-weight: 700; color: white; letter-spacing: -1px;">
                    Bài Viết Mới Nhất
                </h2>
                <p class="text-muted mb-0" style="color: rgba(255,255,255,0.7); font-size: 18px; font-weight: 400; font-family: 'Plus Jakarta Sans', sans-serif; font-style: italic;">
                    <i class="bi bi-journal-bookmark me-2" style="color: #2a5298;"></i>Khám phá những câu chuyện đặc sắc từ Đà Lạt
                </p>
            </div>
        </div>

        <!-- Magazine Layout Blog Grid -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var post in Model)
                {
                    var isNew = (DateTime.Now - post.PostedDate).TotalDays <= 7;
                    var readingTime = Math.Max(1, (int)Math.Ceiling((post.Content?.Length ?? 0) / 1000.0));
                    
                    <div class="col-md-6 col-xl-4">
                        <article class="magazine-card modern-magazine-card" 
                                 style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; overflow: hidden; cursor: pointer; transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94); height: 100%; display: flex; flex-direction: column; box-shadow: 0 15px 35px rgba(0,0,0,0.3);"
                                 onclick="window.location.href='@Url.Action("Detail", "Blog", new { id = post.Id })'">
                            
                            <!-- Magazine Cover Image -->
                            <div class="position-relative magazine-cover" style="height: 300px; overflow: hidden; flex-shrink: 0;">
                                @if (!string.IsNullOrEmpty(post.ImageUrl))
                                {
                                    var imageUrl = post.ImageUrl.StartsWith("~") ? Url.Content(post.ImageUrl) : 
                                                  post.ImageUrl.Contains("/") ? post.ImageUrl : 
                                                  Url.Content($"~/Images/{System.IO.Path.GetFileName(post.ImageUrl)}");
                                    <img src="@imageUrl" alt="@post.Title" 
                                         style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease;"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <div class="magazine-placeholder" style="width: 100%; height: 100%; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #74b9ff 100%); display: none; align-items: center; justify-content: center; position: absolute; top: 0; left: 0;">
                                        <div class="magazine-icon-container" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; border: 1px solid rgba(255,255,255,0.2);">
                                            <i class="bi bi-journal-text" style="font-size: 48px; color: rgba(255,255,255,0.9);"></i>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="magazine-placeholder" style="width: 100%; height: 100%; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 50%, #74b9ff 100%); display: flex; align-items: center; justify-content: center; position: relative;">
                                        <div class="magazine-icon-container" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; border: 1px solid rgba(255,255,255,0.2);">
                                            <i class="bi bi-journal-text" style="font-size: 48px; color: rgba(255,255,255,0.9);"></i>
                                        </div>
                                        <!-- Paper texture overlay -->
                                        <div class="paper-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22 viewBox=%220 0 100 100%22%3E%3Cdefs%3E%3Cpattern id=%22paper%22 x=%220%22 y=%220%22 width=%2220%22 height=%2220%22 patternUnits=%22userSpaceOnUse%22%3E%3Ccircle cx=%2210%22 cy=%2210%22 r=%221%22 fill=%22%23ffffff%22 opacity=%220.1%22/%3E%3C/pattern%3E%3C/defs%3E%3Crect width=%22100%22 height=%22100%22 fill=%22url(%23paper)%22/%3E%3C/svg%3E'); opacity: 0.3;"></div>
                                    </div>
                                }
                                
                                <!-- New Badge -->
                                @if (isNew)
                                {
                                    <div class="position-absolute top-0 start-0 m-3">
                                        <div class="new-badge" style="background: linear-gradient(135deg, #ff3838, #ff6b6b); color: white; padding: 8px 15px; border-radius: 20px; font-size: 12px; font-weight: 700; box-shadow: 0 5px 15px rgba(255,56,56,0.4); font-family: 'Plus Jakarta Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.5px;">
                                            <i class="bi bi-star-fill me-1"></i>Mới
                                        </div>
                                    </div>
                                }
                                
                                <!-- Date Badge (Magazine Style) -->
                                <div class="position-absolute top-0 end-0 m-3">
                                    <div class="date-badge-magazine" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(15px); color: white; padding: 12px 18px; border-radius: 15px; font-size: 12px; font-weight: 600; border: 1px solid rgba(255,255,255,0.2); font-family: 'Plus Jakarta Sans', sans-serif;">
                                        <div style="font-size: 10px; opacity: 0.8; text-transform: uppercase; margin-bottom: 2px;">@post.PostedDate.ToString("MMM")</div>
                                        <div style="font-size: 16px; font-weight: 800; line-height: 1;">@post.PostedDate.Day</div>
                                    </div>
                                </div>
                                
                                <!-- Reading Time Badge -->
                                <div class="position-absolute bottom-0 start-0 m-3">
                                    <div class="reading-time-badge" style="background: rgba(42,82,152,0.9); backdrop-filter: blur(15px); color: white; padding: 8px 15px; border-radius: 20px; font-size: 11px; font-weight: 600; border: 1px solid rgba(255,255,255,0.2); font-family: 'Plus Jakarta Sans', sans-serif;">
                                        <i class="bi bi-clock me-1"></i>@readingTime phút đọc
                                    </div>
                                </div>
                                
                                <!-- Floating Read Button -->
                                <div class="position-absolute bottom-0 end-0 m-3">
                                    <button class="btn floating-read-btn" style="background: linear-gradient(135deg, #1e3c72, #2a5298); border: none; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 8px 20px rgba(30,60,114,0.4);">
                                        <i class="bi bi-arrow-right" style="color: white; font-size: 18px; font-weight: 600; transition: transform 0.3s ease;"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Magazine Content -->
                            <div class="p-4" style="flex-grow: 1; display: flex; flex-direction: column; font-family: 'Plus Jakarta Sans', sans-serif;">
                                <!-- Author Info -->
                                @if (!string.IsNullOrEmpty(post.Author))
                                {
                                    <div class="author-info mb-3" style="display: flex; align-items: center; font-size: 12px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500;">
                                        <i class="bi bi-person-circle me-2" style="color: #2a5298; font-size: 16px;"></i>
                                        <span>@post.Author</span>
                                    </div>
                                }
                                
                                <!-- Magazine Title (Serif Font) -->
                                <h3 class="mb-3" style="font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: white; line-height: 1.2; flex-grow: 0; letter-spacing: -0.5px;">
                                    @post.Title
                                </h3>
                                
                                <!-- Content Preview -->
                                <p class="mb-4" style="color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.7; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; font-family: 'Plus Jakarta Sans', sans-serif;">
                                    @((post.Content?.Length > 120) ? post.Content.Substring(0, 120) + "..." : post.Content ?? "")
                                </p>
                                
                                <!-- Magazine Footer -->
                                <div class="d-flex align-items-center justify-content-between mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                    <div class="read-more" style="color: #2a5298; font-weight: 600; font-size: 14px; transition: all 0.3s ease; display: flex; align-items: center; font-family: 'Plus Jakarta Sans', sans-serif;">
                                        Đọc tiếp <i class="bi bi-arrow-right ms-2 read-arrow" style="transition: transform 0.3s ease;"></i>
                                    </div>
                                    <div class="article-meta" style="color: rgba(255,255,255,0.5); font-size: 12px; display: flex; align-items: center;">
                                        <i class="bi bi-eye me-1"></i>
                                        <span>@((new Random().Next(50, 500)))</span>
                                    </div>
                                </div>
                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <!-- Modern Empty State -->
                <div class="col-12 text-center py-5">
                    <div class="empty-state glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border-radius: 25px; padding: 80px 50px; border: 1px solid rgba(255,255,255,0.1); max-width: 500px; margin: 0 auto;">
                        <div class="empty-icon mb-4" style="background: linear-gradient(135deg, #1e3c72, #2a5298); width: 80px; height: 80px; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                            <i class="bi bi-journal-x" style="font-size: 40px; color: white;"></i>
                        </div>
                        <h3 class="mt-3 mb-3" style="color: white; font-size: 28px; font-weight: 700; font-family: 'Playfair Display', serif;">Chưa có bài viết nào</h3>
                        <p class="text-muted mb-4" style="color: rgba(255,255,255,0.6); font-size: 16px; line-height: 1.6; font-family: 'Plus Jakarta Sans', sans-serif;">
                            Các bài viết đặc sắc sẽ được cập nhật sớm nhất
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<style>
    /* Modern CSS Variables */
    :root {
        --primary-blue: #1e3c72;
        --primary-blue-light: #2a5298;
        --accent-blue: #74b9ff;
        --accent-red: #ff3838;
        --glass-bg: rgba(255,255,255,0.05);
        --glass-border: rgba(255,255,255,0.1);
        --text-primary: #ffffff;
        --text-secondary: rgba(255,255,255,0.8);
        --text-muted: rgba(255,255,255,0.6);
        --shadow-light: 0 10px 30px rgba(0,0,0,0.3);
        --shadow-heavy: 0 25px 50px rgba(0,0,0,0.4);
        --blur-light: blur(15px);
        --blur-heavy: blur(25px);
        --radius-sm: 15px;
        --radius-md: 20px;
        --radius-lg: 25px;
        --transition-smooth: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Magazine Spotlight Background Effects */
    .magazine-spotlight-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .spotlight-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(40px);
        opacity: 0.4;
        animation: magazineSpotlight 12s ease-in-out infinite;
    }

    .spotlight-orb-1 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(30,60,114,0.4) 0%, transparent 70%);
        top: 20%;
        left: 10%;
        animation-delay: 0s;
    }

    .spotlight-orb-2 {
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(42,82,152,0.3) 0%, transparent 70%);
        top: 60%;
        right: 15%;
        animation-delay: 4s;
    }

    .spotlight-orb-3 {
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(116,185,255,0.2) 0%, transparent 70%);
        bottom: 30%;
        left: 60%;
        animation-delay: 8s;
    }

    /* Paper Texture Background */
    .paper-texture-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .paper-grain {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.1;
        animation: paperFloat 20s ease-in-out infinite;
    }

    .paper-grain-1 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        top: 10%;
        right: 5%;
        animation-delay: 0s;
    }

    .paper-grain-2 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
        bottom: 20%;
        left: 10%;
        animation-delay: 7s;
    }

    .paper-grain-3 {
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
        top: 50%;
        left: 50%;
        animation-delay: 14s;
    }

    /* Hero Section Animations */
    .hero-title {
        animation: fadeInUp 1s ease-out;
    }
    
    .hero-subtitle {
        animation: fadeInUp 1s ease-out 0.2s both;
    }
    
    .hero-search-box {
        animation: fadeInUp 1s ease-out 0.4s both;
    }
    
    .hero-search-btn:hover {
        background: linear-gradient(135deg, var(--primary-blue-light), var(--accent-blue)) !important;
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(30,60,114,0.5) !important;
    }

    .modern-search:focus {
        box-shadow: 0 0 0 4px rgba(30,60,114,0.2) !important;
        transform: scale(1.02);
    }

    /* Admin Toolbar */
    .admin-toolbar {
        animation: slideInRight 0.8s ease-out;
    }

    .admin-btn:hover {
        background: linear-gradient(135deg, var(--primary-blue-light), var(--accent-blue)) !important;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(30,60,114,0.4) !important;
    }

    /* Modern Magazine Card Styles */
    .modern-magazine-card {
        transition: var(--transition-smooth);
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        position: relative;
        overflow: hidden;
    }

    .modern-magazine-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, transparent, rgba(30,60,114,0.05));
        opacity: 0;
        transition: opacity var(--transition-smooth);
        pointer-events: none;
        border-radius: inherit;
    }

    .modern-magazine-card:hover {
        transform: translateY(-15px) scale(1.02);
        box-shadow: 
            0 30px 60px rgba(0,0,0,0.5),
            0 0 40px rgba(30,60,114,0.3),
            0 0 0 1px rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.08) !important;
    }

    .modern-magazine-card:hover::before {
        opacity: 1;
    }

    .modern-magazine-card:hover .magazine-cover img {
        transform: scale(1.1);
    }

    .modern-magazine-card:hover .read-more {
        transform: translateX(8px);
        color: #4a90e2 !important;
    }

    .modern-magazine-card:hover .read-arrow {
        transform: rotate(45deg);
    }

    .modern-magazine-card:hover .floating-read-btn {
        transform: scale(1.1) rotate(90deg);
        box-shadow: 0 12px 30px rgba(30,60,114,0.6) !important;
    }

    .modern-magazine-card:hover .floating-read-btn i {
        transform: rotate(-90deg);
    }

    .modern-magazine-card:hover .new-badge {
        transform: scale(1.05);
        box-shadow: 0 8px 20px rgba(255,56,56,0.6) !important;
    }

    .modern-magazine-card:hover .date-badge-magazine {
        transform: scale(1.05);
        background: rgba(30,60,114,0.9) !important;
    }

    .modern-magazine-card:hover .reading-time-badge {
        transform: scale(1.05);
        background: rgba(116,185,255,0.9) !important;
    }

    /* Magazine Cover Effects */
    .magazine-cover {
        position: relative;
        overflow: hidden;
    }

    .magazine-cover::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
        pointer-events: none;
    }

    .modern-magazine-card:hover .magazine-cover::after {
        transform: translateX(100%);
    }

    /* Floating Elements */
    .floating-read-btn {
        transition: var(--transition-smooth);
    }

    /* Badge Animations */
    .new-badge {
        animation: pulse 2s infinite;
    }

    /* Enhanced Empty State */
    .empty-state:hover {
        transform: translateY(-5px);
        box-shadow: 
            0 35px 70px rgba(0,0,0,0.6),
            0 0 40px rgba(30,60,114,0.2) !important;
    }

    /* Glassmorphism Panel Effects */
    .glassmorphism-panel {
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        transition: var(--transition-smooth);
    }

    /* Author Info Hover */
    .author-info {
        transition: var(--transition-smooth);
    }

    .modern-magazine-card:hover .author-info {
        color: rgba(255,255,255,0.8) !important;
    }

    /* Article Meta Hover */
    .article-meta {
        transition: var(--transition-smooth);
    }

    .modern-magazine-card:hover .article-meta {
        color: rgba(255,255,255,0.7) !important;
    }
</style>

@{
    string magazineKeyframes = @"
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes magazineSpotlight {
            0%, 100% { 
                transform: translateY(0px) scale(1);
                opacity: 0.3;
            }
            50% { 
                transform: translateY(-20px) scale(1.1);
                opacity: 0.5;
            }
        }

        @keyframes paperFloat {
            0%, 100% { 
                transform: translateX(0px) translateY(0px);
                opacity: 0.1;
            }
            25% { 
                transform: translateX(20px) translateY(-10px);
                opacity: 0.15;
            }
            50% { 
                transform: translateX(-10px) translateY(15px);
                opacity: 0.08;
            }
            75% { 
                transform: translateX(15px) translateY(-5px);
                opacity: 0.12;
            }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
    ";
    
    string magazineResponsiveCSS = @"
        @media (max-width: 992px) {
            .admin-toolbar {
                position: relative !important;
                top: 0 !important;
                right: 0 !important;
                margin-bottom: 30px;
                display: flex;
                justify-content: center;
            }

            #blog-section {
                padding: 20px 0;
            }

            .hero-section {
                height: 50vh !important;
                margin-top: 60px !important;
            }

            .hero-title {
                font-size: 2.8rem !important;
            }

            .hero-subtitle {
                font-size: 1.1rem !important;
            }

            .hero-search-box {
                padding: 20px !important;
            }

            .modern-magazine-card {
                margin-bottom: 20px;
            }

            .spotlight-orb, .paper-grain {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .hero-section {
                height: 40vh !important;
            }

            .hero-title {
                font-size: 2.2rem !important;
            }

            .hero-search-box .d-flex {
                flex-direction: column !important;
                gap: 15px !important;
            }

            .hero-search-btn {
                width: 100% !important;
            }

            .magazine-cover {
                height: 250px !important;
            }

            .admin-toolbar {
                padding: 12px 20px !important;
            }
        }
    ";
}

<style>
    @Html.Raw(magazineKeyframes)
    @Html.Raw(magazineResponsiveCSS)
</style>
