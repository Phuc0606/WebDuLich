@model List<WebDuLichDaLat.Services.FlightOfferDetails>
@{
    ViewData["Title"] = "Kết quả tìm kiếm chuyến bay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 style="color: #ff6b9d; font-weight: 700;">
                    <i class="bi bi-airplane"></i> Kết quả tìm kiếm
                </h2>
                <a href="@Url.Action("Index", "Flight")" class="btn" 
                   style="background-color: rgba(255,255,255,0.1); color: white; border: none; border-radius: 8px; padding: 10px 20px;">
                    <i class="bi bi-arrow-left"></i> Tìm kiếm lại
                </a>
            </div>
            
            <div class="mt-3" style="color: rgba(255,255,255,0.8);">
                <p class="mb-1">
                    <strong>Từ:</strong> <span style="color: #ff6b9d;">@ViewBag.OriginCode</span> 
                    <strong>Đến:</strong> <span style="color: #ff6b9d;">@ViewBag.DestinationCode</span>
                </p>
                <p class="mb-0">
                    <strong>Ngày:</strong> @ViewBag.DepartureDate | 
                    <strong>Số người:</strong> @ViewBag.Adults | 
                    <strong>Tìm thấy:</strong> @ViewBag.ResultsCount chuyến bay
                </p>
            </div>
        </div>
    </div>

    <!-- Results -->
    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var flight in Model)
            {
                <div class="col-12 mb-4">
                    <div class="card shadow-lg" style="background-color: #2a2a2a; border-radius: 15px; border: 1px solid rgba(255,107,157,0.3);">
                        <div class="card-body p-4">
                            <!-- Header: Giá và Hãng bay -->
                            <div class="row align-items-center mb-3">
                                <div class="col-md-6">
                                    <h4 style="color: #ff6b9d; font-weight: 700; margin: 0;">
                                        <i class="bi bi-airplane-fill"></i> @flight.CarrierCode
                                    </h4>
                                    <small style="color: rgba(255,255,255,0.6);">
                                        @flight.NumberOfStops chặng dừng
                                    </small>
                                </div>
                                <div class="col-md-6 text-end">
                                    <h3 style="color: #ffd700; font-weight: 700; margin: 0;">
                                        @flight.Price @flight.Currency
                                    </h3>
                                    <small style="color: rgba(255,255,255,0.6);">
                                        @flight.NumberOfBookableSeats ghế còn lại
                                    </small>
                                </div>
                            </div>

                            <!-- Thông tin chuyến bay -->
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <div style="background-color: rgba(255,107,157,0.1); padding: 15px; border-radius: 10px;">
                                        <div style="color: rgba(255,255,255,0.7); font-size: 12px; margin-bottom: 5px;">KHỞI HÀNH</div>
                                        <div style="color: white; font-size: 18px; font-weight: 600;">@flight.DepartureAirport</div>
                                        <div style="color: rgba(255,255,255,0.8); font-size: 14px;">
                                            @if (!string.IsNullOrEmpty(flight.DepartureTime))
                                            {
                                                var departureTime = DateTime.TryParse(flight.DepartureTime, out var dt) 
                                                    ? dt.ToString("HH:mm") 
                                                    : flight.DepartureTime;
                                                @departureTime
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4 text-center align-self-center">
                                    <i class="bi bi-arrow-right" style="font-size: 24px; color: #ff6b9d;"></i>
                                    <div style="color: rgba(255,255,255,0.6); font-size: 12px; margin-top: 5px;">
                                        @flight.NumberOfStops chặng
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div style="background-color: rgba(255,107,157,0.1); padding: 15px; border-radius: 10px;">
                                        <div style="color: rgba(255,255,255,0.7); font-size: 12px; margin-bottom: 5px;">ĐẾN</div>
                                        <div style="color: white; font-size: 18px; font-weight: 600;">@flight.ArrivalAirport</div>
                                        <div style="color: rgba(255,255,255,0.8); font-size: 14px;">
                                            @if (!string.IsNullOrEmpty(flight.ArrivalTime))
                                            {
                                                var arrivalTime = DateTime.TryParse(flight.ArrivalTime, out var dt) 
                                                    ? dt.ToString("HH:mm") 
                                                    : flight.ArrivalTime;
                                                @arrivalTime
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Chi tiết từng chặng -->
                            @if (flight.Segments != null && flight.Segments.Any())
                            {
                                <div class="mt-3" style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;">
                                    <h6 style="color: white; font-weight: 600; margin-bottom: 15px;">
                                        <i class="bi bi-list-ul"></i> Chi tiết chặng bay:
                                    </h6>
                                    @foreach (var segment in flight.Segments)
                                    {
                                        <div class="mb-2 p-2" style="background-color: rgba(255,255,255,0.05); border-radius: 8px;">
                                            <div class="row align-items-center">
                                                <div class="col-md-3">
                                                    <span style="color: #ff6b9d; font-weight: 600;">@segment.CarrierCode</span>
                                                </div>
                                                <div class="col-md-3">
                                                    <small style="color: rgba(255,255,255,0.7);">@segment.DepartureAirport</small>
                                                    <div style="color: white;">@segment.DepartureTime</div>
                                                </div>
                                                <div class="col-md-3 text-center">
                                                    <i class="bi bi-arrow-right" style="color: #ff6b9d;"></i>
                                                    <div style="color: rgba(255,255,255,0.6); font-size: 11px;">@segment.Duration</div>
                                                </div>
                                                <div class="col-md-3 text-end">
                                                    <small style="color: rgba(255,255,255,0.7);">@segment.ArrivalAirport</small>
                                                    <div style="color: white;">@segment.ArrivalTime</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Button đặt vé -->
                            <div class="mt-4">
                                <button class="btn w-100" 
                                        style="background-color: #ff6b9d; color: white; border: none; border-radius: 8px; padding: 12px; font-weight: 600;"
                                        onclick="alert('Tính năng đặt vé sẽ được tích hợp sau!')">
                                    <i class="bi bi-cart-check"></i> Đặt vé ngay
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert" style="background-color: rgba(255,193,7,0.1); border: 1px solid rgba(255,193,7,0.3); color: white;">
            <i class="bi bi-exclamation-triangle-fill"></i> Không tìm thấy chuyến bay nào. Vui lòng thử lại với thông tin khác.
        </div>
    }
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(255,107,157,0.2) !important;
    }

    .btn:hover {
        background-color: #ff5a8a !important;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 107, 157, 0.4);
    }
</style>





















