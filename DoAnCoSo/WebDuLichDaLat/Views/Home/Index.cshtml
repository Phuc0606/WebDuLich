<!-- JavaScript -->
<script>
    // Booking tab switching
    function switchBookingTab(tabName) {
        // Remove active class from all tabs and forms
        document.querySelectorAll('.booking-tab').forEach(tab => {
            tab.classList.remove('active');
        });
        document.querySelectorAll('.booking-form').forEach(form => {
            form.classList.remove('active');
        });
        
        // Add active class to selected tab and form
        document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
        document.getElementById(`${tabName}-form`).classList.add('active');
    }
    
    // Search functions
    function searchPlaces() {
        const searchTerm = document.querySelector('#places-form .form-input').value;
        if (searchTerm.trim()) {
            window.location.href = `@Url.Action("Index", "TouristPlace")?search=${encodeURIComponent(searchTerm)}`;
        } else {
            window.location.href = '@Url.Action("Index", "TouristPlace")';
        }
    }
    
    function searchHotels() {
        const location = document.querySelector('#hotels-form .form-input').value;
        if (location.trim()) {
            window.location.href = `@Url.Action("Index", "Hotel")?location=${encodeURIComponent(location)}`;
        } else {
            window.location.href = '@Url.Action("Index", "Hotel")';
        }
    }
    
    function searchTransport() {
        const from = document.querySelector('#transport-form .form-input').value;
        if (from.trim()) {
            window.location.href = `@Url.Action("Index", "TripPlanner")?from=${encodeURIComponent(from)}`;
        } else {
            window.location.href = '@Url.Action("Index", "TripPlanner")';
        }
    }
    
    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
        // Enter key support for search
        document.querySelectorAll('.form-input').forEach(input => {
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const form = this.closest('.booking-form');
                    const searchBtn = form.querySelector('.search-btn');
                    if (searchBtn) {
                        searchBtn.click();
                    }
                }
            });
        });
        
        // Scroll animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('animated');
                }
            });
        }, observerOptions);
        
        // Add animation classes to elements
        document.querySelectorAll('.destination-card, .feature-card, .event-card').forEach((el, index) => {
            el.classList.add('animate-on-scroll');
            el.style.transitionDelay = `${index * 0.1}s`;
            observer.observe(el);
        });
        
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
        
        // Image lazy loading with error handling
        const images = document.querySelectorAll('img');
        images.forEach(img => {
            img.addEventListener('error', function() {
                // If image fails to load, try fallback
                if (!this.src.includes('unsplash.com')) {
                    this.src = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&h=600&fit=crop';
                }
            });
        });
        
        // Add loading states
        const cards = document.querySelectorAll('.destination-card, .event-card');
        cards.forEach(card => {
            const img = card.querySelector('img');
            if (img) {
                img.addEventListener('load', function() {
                    card.classList.add('loaded');
                });
            }
        });
    });
    
    // Parallax effect for hero background
    window.addEventListener('scroll', function() {
        const scrolled = window.pageYOffset;
        const parallax = document.querySelector('.hero-background');
        const speed = scrolled * 0.5;
        
        if (parallax) {
            parallax.style.transform = `translateY(${speed}px)`;
        }
    });
</script>