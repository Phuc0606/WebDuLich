@model WebDuLichDaLat.Models.Festival
@{
    Layout = "~/Views/Shared/_LayoutNoFooter.cshtml";
    ViewData["Title"] = Model.Title;
}

<!-- Import Modern Font -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<!-- Main Content Section -->
<section id="festival-detail-section" style="background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%); color: white; min-height: 100vh; padding: 80px 0 40px 0; font-family: 'Plus Jakarta Sans', sans-serif; position: relative; overflow: hidden; margin-top: 0;">
    <!-- Background Stage Lights -->
    <div class="stage-lights-bg">
        <div class="stage-light stage-light-1"></div>
        <div class="stage-light stage-light-2"></div>
        <div class="stage-light stage-light-3"></div>
        <div class="stage-light stage-light-4"></div>
    </div>
    
    <div class="container">
        <!-- Modern Back Button -->
        <div class="mb-4">
            <a href="@Url.Action("Index", "Festival")" class="btn back-btn" 
               style="background: rgba(255,255,255,0.08); backdrop-filter: blur(15px); color: white; border: 1px solid rgba(255,255,255,0.15); border-radius: 15px; padding: 15px 30px; text-decoration: none; font-weight: 500; transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
            </a>
        </div>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Modern Hero Section -->
                <div class="mb-5 hero-section-container">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        var imageUrl = Model.ImageUrl.StartsWith("~") ? Url.Content(Model.ImageUrl) : 
                                      Model.ImageUrl.Contains("/") ? Model.ImageUrl : 
                                      Url.Content($"~/Images/{System.IO.Path.GetFileName(Model.ImageUrl)}");
                        <div class="hero-image-full">
                            <div class="position-relative hero-parallax" style="height: 60vh; border-radius: 25px; overflow: hidden; box-shadow: 0 25px 50px rgba(0,0,0,0.4); margin-bottom: 30px;">
                                <img src="@imageUrl" alt="@Model.Title" 
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #8a2be2 0%, #ff6b9d 50%, #ffd700 100%); display: none; align-items: center; justify-content: center; position: absolute; top: 0; left: 0;">
                                    <div class="event-icon-container" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(15px); border-radius: 25px; padding: 40px; border: 1px solid rgba(255,255,255,0.2);">
                                        <i class="bi bi-calendar-event" style="font-size: 80px; color: rgba(255,255,255,0.9);"></i>
                                    </div>
                                </div>
                                <!-- Modern Overlay -->
                                <div class="position-absolute bottom-0 start-0 end-0" style="background: linear-gradient(transparent, rgba(0,0,0,0.8)); height: 200px; display: flex; align-items: end; padding: 40px;">
                                    <div class="container">
                                        <div class="floating-element">
                                            <h1 class="mb-3" style="font-size: 3.5rem; font-weight: 800; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.7); letter-spacing: -1px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                                @Model.Title
                                            </h1>
                                            @if (!string.IsNullOrEmpty(Model.EventType))
                                            {
                                                <p class="mb-0" style="font-size: 1.3rem; color: rgba(255,255,255,0.9); text-shadow: 1px 1px 2px rgba(0,0,0,0.5); display: flex; align-items: center;">
                                                    <i class="bi bi-star me-3" style="color: #ffd700; font-size: 1.5rem;"></i>@Model.EventType
                                                </p>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <!-- Modern Date Box -->
                                <div class="position-absolute top-0 start-0 m-4">
                                    <div class="date-box-large" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(15px); border-radius: 20px; padding: 20px; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.2); min-width: 90px;">
                                        <div style="color: #8a2be2; font-size: 14px; font-weight: 600; text-transform: uppercase; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                            @Model.StartDate.ToString("MMM", new System.Globalization.CultureInfo("vi-VN"))
                                        </div>
                                        <div style="color: #333; font-size: 32px; font-weight: 800; line-height: 1; font-family: 'Plus Jakarta Sans', sans-serif;">
                                            @Model.StartDate.Day
                                        </div>
                                        @if (Model.EndDate.HasValue && Model.EndDate.Value != Model.StartDate)
                                        {
                                            <div style="color: #666; font-size: 12px; margin-top: 5px; font-weight: 500;">
                                                - @Model.EndDate.Value.Day
                                            </div>
                                        }
                                    </div>
                                </div>
                                <!-- Modern Floating Action Buttons -->
                                <div class="position-absolute top-0 end-0 m-4">
                                    <div class="d-flex flex-column gap-3">
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(15px); border: none; border-radius: 50%; width: 55px; height: 55px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 10px 25px rgba(0,0,0,0.3);">
                                            <i class="bi bi-heart" style="color: #8a2be2; font-size: 20px;"></i>
                                        </button>
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(15px); border: none; border-radius: 50%; width: 55px; height: 55px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 10px 25px rgba(0,0,0,0.3); animation-delay: 0.2s;">
                                            <i class="bi bi-share" style="color: #8a2be2; font-size: 20px;"></i>
                                        </button>
                                        <button class="btn floating-element" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(15px); border: none; border-radius: 50%; width: 55px; height: 55px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; box-shadow: 0 10px 25px rgba(0,0,0,0.3); animation-delay: 0.4s;">
                                            <i class="bi bi-camera" style="color: #ffd700; font-size: 20px;"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="hero-image-full">
                            <div class="position-relative hero-parallax" style="height: 60vh; background: linear-gradient(135deg, #8a2be2 0%, #ff6b9d 50%, #ffd700 100%); border-radius: 25px; display: flex; align-items: center; justify-content: center; box-shadow: 0 25px 50px rgba(0,0,0,0.4); margin-bottom: 30px;">
                                <div class="text-center floating-element">
                                    <div class="event-icon-container mb-4" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(15px); border-radius: 25px; padding: 40px; border: 1px solid rgba(255,255,255,0.2); display: inline-block;">
                                        <i class="bi bi-calendar-event" style="font-size: 80px; color: rgba(255,255,255,0.9);"></i>
                                    </div>
                                    <h1 class="mb-3" style="font-size: 3.5rem; font-weight: 800; color: white; font-family: 'Plus Jakarta Sans', sans-serif;">
                                        @Model.Title
                                    </h1>
                                    @if (!string.IsNullOrEmpty(Model.EventType))
                                    {
                                        <p class="mb-0" style="font-size: 1.3rem; color: rgba(255,255,255,0.9);">
                                            <i class="bi bi-star me-3"></i>@Model.EventType
                                        </p>
                                    }
                                </div>
                                <!-- Floating sparkles effect -->
                                <div class="floating-sparkles">
                                    <div class="sparkle" style="position: absolute; width: 4px; height: 4px; background: rgba(255,255,255,0.8); border-radius: 50%; top: 20%; left: 15%; animation: sparkle 2s ease-in-out infinite;"></div>
                                    <div class="sparkle" style="position: absolute; width: 6px; height: 6px; background: rgba(255,215,0,0.6); border-radius: 50%; top: 60%; right: 20%; animation: sparkle 3s ease-in-out infinite 1s;"></div>
                                    <div class="sparkle" style="position: absolute; width: 3px; height: 3px; background: rgba(255,255,255,0.9); border-radius: 50%; bottom: 30%; left: 70%; animation: sparkle 2.5s ease-in-out infinite 2s;"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Modern Description Card -->
                <div class="mb-5 description-card glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; padding: 35px; box-shadow: 0 15px 35px rgba(0,0,0,0.3);">
                    <h3 class="mb-4" style="font-size: 24px; font-weight: 700; color: white; font-family: 'Plus Jakarta Sans', sans-serif;">
                        <div class="d-flex align-items-center">
                            <div class="info-icon" style="background: linear-gradient(135deg, #8a2be2, #ff6b9d); width: 45px; height: 45px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                                <i class="bi bi-info-circle" style="color: white; font-size: 18px;"></i>
                            </div>
                            Giới thiệu sự kiện
                        </div>
                    </h3>
                    <div class="preserve-line-breaks" style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; white-space: pre-line;">
                        @Model.Description
                    </div>
                </div>

                <!-- Detailed Content -->
                @if (!string.IsNullOrEmpty(Model.Content))
                {
                    <div class="mb-5 content-card glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; padding: 35px; box-shadow: 0 15px 35px rgba(0,0,0,0.3);">
                        <div class="d-flex align-items-center mb-4">
                            <div class="content-icon" style="background: linear-gradient(135deg, #8a2be2, #ff6b9d); width: 45px; height: 45px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
                                <i class="bi bi-file-text" style="color: white; font-size: 18px;"></i>
                            </div>
                            <h3 style="font-size: 24px; font-weight: 700; color: white; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0;">
                                Chi tiết sự kiện
                            </h3>
                        </div>
                        <div class="preserve-line-breaks" style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; white-space: pre-line;">
                            @Model.Content
                        </div>
                    </div>
                }
            </div>

            <!-- Modern Sticky Info Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-info-card" style="position: sticky; top: 100px;">
                    <!-- Main Event Info Card -->
                    <div class="event-info-card glassmorphism-panel" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(30px); border: 1px solid rgba(255,255,255,0.15); border-radius: 25px; padding: 40px; box-shadow: 0 25px 50px rgba(0,0,0,0.4); margin-bottom: 25px;">
                        <!-- Event Status -->
                        <div class="event-status-section mb-4" style="text-align: center; padding: 25px; background: linear-gradient(135deg, rgba(138,43,226,0.15), rgba(255,107,157,0.1)); border-radius: 20px; border: 1px solid rgba(138,43,226,0.3);">
                            <div style="color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 8px; font-weight: 500; font-family: 'Plus Jakarta Sans', sans-serif;">Trạng thái sự kiện</div>
                            <div class="status-display" style="font-size: 1.8rem; font-weight: 800; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                @if (Model.StartDate > DateTime.Now)
                                {
                                    <span style="color: #ffd700;"><i class="bi bi-clock me-2"></i>Sắp diễn ra</span>
                                }
                                else if (Model.EndDate.HasValue && Model.EndDate.Value >= DateTime.Now)
                                {
                                    <span style="color: #00ff88;"><i class="bi bi-play-circle me-2"></i>Đang diễn ra</span>
                                }
                                else
                                {
                                    <span style="color: #ff6b9d;"><i class="bi bi-check-circle me-2"></i>Đã kết thúc</span>
                                }
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="action-buttons mb-4">
                            @if (!string.IsNullOrEmpty(Model.Website))
                            {
                                <a href="@Model.Website" target="_blank" class="btn event-website-btn w-100 mb-3" 
                                   style="background: linear-gradient(135deg, #8a2be2, #ff6b9d); color: white; border: none; border-radius: 20px; padding: 20px; font-size: 18px; font-weight: 700; box-shadow: 0 12px 35px rgba(138,43,226,0.4); transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif; text-decoration: none; display: block; text-align: center;">
                                    <i class="bi bi-globe me-2"></i>Xem website chính thức
                                </a>
                            }
                            <button class="btn share-btn w-100" 
                                    style="background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; padding: 18px; font-size: 16px; font-weight: 600; transition: all 0.3s ease; font-family: 'Plus Jakarta Sans', sans-serif;">
                                <i class="bi bi-share me-2"></i>Chia sẻ sự kiện
                            </button>
                        </div>
                    </div>

                    <!-- Event Details Card -->
                    <div class="event-details-card glassmorphism-panel" style="background: rgba(255,255,255,0.05); backdrop-filter: blur(25px); border: 1px solid rgba(255,255,255,0.1); border-radius: 25px; padding: 30px; box-shadow: 0 15px 35px rgba(0,0,0,0.3);">
                        <h4 class="mb-4" style="font-size: 18px; font-weight: 700; color: white; font-family: 'Plus Jakarta Sans', sans-serif;">
                            <div class="d-flex align-items-center">
                                <div class="details-icon" style="background: linear-gradient(135deg, #8a2be2, #ff6b9d); width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-right: 12px;">
                                    <i class="bi bi-calendar-check" style="color: white; font-size: 16px;"></i>
                                </div>
                                Thông tin chi tiết
                            </div>
                        </h4>

                        <!-- Date & Time -->
                        <div class="detail-item mb-3" style="padding: 18px; background: rgba(255,255,255,0.05); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s ease;">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-calendar-event me-3" style="color: #8a2be2; font-size: 18px; margin-top: 2px;"></i>
                                <div>
                                    <div style="font-weight: 600; color: white; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">Thời gian</div>
                                    <div style="color: rgba(255,255,255,0.7); font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif;">
                                        @Model.StartDate.ToString("dd/MM/yyyy")
                                        @if (Model.EndDate.HasValue && Model.EndDate.Value != Model.StartDate)
                                        {
                                            <text> - @Model.EndDate.Value.ToString("dd/MM/yyyy")</text>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Time))
                                        {
                                            <br /><span style="color: #ffd700;">@Model.Time</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Location -->
                        @if (!string.IsNullOrEmpty(Model.Location))
                        {
                            <div class="detail-item mb-3" style="padding: 18px; background: rgba(255,255,255,0.05); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s ease;">
                                <div class="d-flex align-items-start">
                                    <i class="bi bi-geo-alt-fill me-3" style="color: #8a2be2; font-size: 18px; margin-top: 2px;"></i>
                                    <div>
                                        <div style="font-weight: 600; color: white; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">Địa điểm</div>
                                        <div style="color: rgba(255,255,255,0.7); font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif;">@Model.Location</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Ticket Price -->
                        @if (!string.IsNullOrEmpty(Model.TicketPrice))
                        {
                            <div class="detail-item mb-3" style="padding: 18px; background: rgba(255,255,255,0.05); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s ease;">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-ticket-perforated-fill me-3" style="color: #ffd700; font-size: 18px;"></i>
                                    <div>
                                        <div style="font-weight: 600; color: white; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">Giá vé</div>
                                        <div style="color: #ffd700; font-size: 16px; font-weight: 600; font-family: 'Plus Jakarta Sans', sans-serif;">
                                            @Model.TicketPrice
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Contact -->
                        @if (!string.IsNullOrEmpty(Model.ContactInfo))
                        {
                            <div class="detail-item mb-3" style="padding: 18px; background: rgba(255,255,255,0.05); border-radius: 15px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s ease;">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-telephone-fill me-3" style="color: #8a2be2; font-size: 18px;"></i>
                                    <div>
                                        <div style="font-weight: 600; color: white; margin-bottom: 5px; font-family: 'Plus Jakarta Sans', sans-serif;">Liên hệ</div>
                                        <div style="color: rgba(255,255,255,0.7); font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif;">@Model.ContactInfo</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Modern CSS Variables */
    :root {
        --primary-purple: #8a2be2;
        --primary-pink: #ff6b9d;
        --accent-gold: #ffd700;
        --glass-bg: rgba(255,255,255,0.05);
        --glass-border: rgba(255,255,255,0.1);
        --text-primary: #ffffff;
        --text-secondary: rgba(255,255,255,0.8);
        --text-muted: rgba(255,255,255,0.6);
        --shadow-light: 0 15px 35px rgba(0,0,0,0.3);
        --shadow-heavy: 0 25px 50px rgba(0,0,0,0.4);
        --blur-light: blur(15px);
        --blur-heavy: blur(25px);
        --blur-ultra: blur(30px);
        --radius-sm: 15px;
        --radius-md: 20px;
        --radius-lg: 25px;
        --transition-smooth: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* Background Stage Lights */
    .stage-lights-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        overflow: hidden;
    }

    .stage-light {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.2;
        animation: stageLight 15s ease-in-out infinite;
    }

    .stage-light-1 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(138,43,226,0.3) 0%, transparent 70%);
        top: 10%;
        right: 5%;
        animation-delay: 0s;
    }

    .stage-light-2 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,107,157,0.2) 0%, transparent 70%);
        bottom: 20%;
        left: 10%;
        animation-delay: 5s;
    }

    .stage-light-3 {
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(255,215,0,0.15) 0%, transparent 70%);
        top: 60%;
        left: 50%;
        animation-delay: 10s;
    }

    .stage-light-4 {
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(138,43,226,0.25) 0%, transparent 70%);
        bottom: 40%;
        right: 30%;
        animation-delay: 12s;
    }

    /* Glassmorphism Effects */
    .glassmorphism-panel {
        backdrop-filter: var(--blur-heavy);
        -webkit-backdrop-filter: var(--blur-heavy);
        transition: var(--transition-smooth);
        position: relative;
    }

    .glassmorphism-panel::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(138,43,226,0.05), rgba(255,107,157,0.03));
        border-radius: inherit;
        opacity: 0;
        transition: opacity var(--transition-smooth);
        pointer-events: none;
    }

    .glassmorphism-panel:hover::before {
        opacity: 1;
    }

    .glassmorphism-panel:hover {
        background: rgba(255,255,255,0.08) !important;
        border-color: rgba(255,255,255,0.15) !important;
        transform: translateY(-2px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 30px rgba(138,43,226,0.1) !important;
    }

    /* Back Button */
    .back-btn:hover {
        background: rgba(255,255,255,0.12) !important;
        border-color: rgba(255,255,255,0.2) !important;
        transform: translateY(-2px);
    }

    /* Hero Section */
    .hero-section-container {
        animation: fadeInUp 0.8s ease-out;
    }

    /* Cards Animation */
    .description-card {
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    .content-card {
        animation: fadeInUp 0.8s ease-out 0.6s both;
    }

    /* Sticky Info Card */
    .sticky-info-card {
        animation: fadeInUp 0.8s ease-out 0.8s both;
    }

    .event-info-card {
        transition: var(--transition-smooth);
        position: relative;
        overflow: hidden;
    }

    .event-info-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 40px rgba(138,43,226,0.15) !important;
    }

    /* Action Buttons */
    .event-website-btn {
        position: relative;
        overflow: hidden;
    }

    .event-website-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }

    .event-website-btn:hover::before {
        left: 100%;
    }

    .event-website-btn:hover {
        background: linear-gradient(135deg, var(--primary-pink), var(--primary-purple)) !important;
        transform: translateY(-3px);
        box-shadow: 0 18px 45px rgba(138,43,226,0.5) !important;
    }

    .share-btn:hover {
        background: rgba(255,255,255,0.12) !important;
        border-color: rgba(255,255,255,0.2) !important;
        transform: translateY(-2px);
    }

    /* Detail Items */
    .detail-item {
        transition: var(--transition-smooth);
        position: relative;
        overflow: hidden;
    }

    .detail-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(138,43,226,0.1), transparent);
        transition: left 0.5s;
    }

    .detail-item:hover::before {
        left: 100%;
    }

    .detail-item:hover {
        background: rgba(255,255,255,0.1) !important;
        border-color: rgba(255,255,255,0.15) !important;
        transform: translateX(5px);
    }

    /* Floating Elements */
    .floating-element {
        animation: float 6s ease-in-out infinite;
    }

    .floating-element:hover {
        transform: translateY(-8px) !important;
        box-shadow: 0 15px 30px rgba(0,0,0,0.4) !important;
    }

    /* Floating Sparkles */
    .sparkle {
        animation: sparkle 2s ease-in-out infinite;
    }

    /* Date Box Large */
    .date-box-large {
        transition: var(--transition-smooth);
    }

    /* Status Display Animation */
    .status-display {
        animation: pulse 2s infinite;
    }
</style>

@{
    string festivalDetailKeyframes = @"
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-10px) rotate(1deg); }
            66% { transform: translateY(-5px) rotate(-1deg); }
        }

        @keyframes stageLight {
            0%, 100% { 
                transform: translateX(0px) translateY(0px);
                opacity: 0.2;
            }
            25% { 
                transform: translateX(20px) translateY(-10px);
                opacity: 0.4;
            }
            50% { 
                transform: translateX(-10px) translateY(15px);
                opacity: 0.3;
            }
            75% { 
                transform: translateX(15px) translateY(-5px);
                opacity: 0.35;
            }
        }

        @keyframes sparkle {
            0%, 100% { 
                transform: scale(0) rotate(0deg);
                opacity: 0;
            }
            50% { 
                transform: scale(1) rotate(180deg);
                opacity: 1;
            }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
    ";
    
    string festivalDetailResponsiveCSS = @"
        @media (max-width: 992px) {
            .sticky-info-card {
                position: relative !important;
                top: 0 !important;
                margin-top: 30px;
            }

            #festival-detail-section {
                padding: 20px 0;
            }

            .hero-section-container .position-relative {
                height: 300px !important;
            }

            .hero-section-container h1 {
                font-size: 2.5rem !important;
            }

            .stage-light {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .event-info-card {
                padding: 30px !important;
            }

            .event-details-card {
                padding: 25px !important;
            }

            .hero-section-container h1 {
                font-size: 2rem !important;
            }

            .date-box-large {
                min-width: 70px !important;
                padding: 15px !important;
            }
        }
    ";
}

<style>
    @Html.Raw(festivalDetailKeyframes)
    @Html.Raw(festivalDetailResponsiveCSS)
</style>

<script>
    // Modern Parallax Effect
    document.addEventListener('DOMContentLoaded', function() {
        const heroParallax = document.querySelector('.hero-parallax');
        const floatingElements = document.querySelectorAll('.floating-element');
        
        if (heroParallax) {
            window.addEventListener('scroll', function() {
                const scrolled = window.pageYOffset;
                const rate = scrolled * -0.3;
                heroParallax.style.transform = `translateY(${rate}px)`;
            });
        }

        // Mouse move parallax effect
        document.addEventListener('mousemove', function(e) {
            const mouseX = e.clientX / window.innerWidth;
            const mouseY = e.clientY / window.innerHeight;
            
            floatingElements.forEach((element, index) => {
                const speed = (index + 1) * 0.3;
                const x = (mouseX - 0.5) * speed;
                const y = (mouseY - 0.5) * speed;
                element.style.transform = `translate(${x}px, ${y}px)`;
            });
        });

        // Smooth scroll for info card
        const infoCard = document.querySelector('.event-info-card');
        if (infoCard) {
            window.addEventListener('scroll', function() {
                const scrolled = window.scrollY;
                const cardTop = infoCard.offsetTop;
                const windowHeight = window.innerHeight;
                
                if (scrolled > cardTop - windowHeight + 100) {
                    infoCard.style.transform = 'translateY(-8px)';
                    infoCard.style.boxShadow = '0 35px 70px rgba(0,0,0,0.6), 0 0 40px rgba(138,43,226,0.15)';
                } else {
                    infoCard.style.transform = 'translateY(0)';
                    infoCard.style.boxShadow = '0 25px 50px rgba(0,0,0,0.4)';
                }
            });
        }
    });
</script>

