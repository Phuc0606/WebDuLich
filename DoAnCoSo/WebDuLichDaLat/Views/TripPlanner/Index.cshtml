        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(139, 69, 255, 0.3);
    }

        .btn-location:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(139, 69, 255, 0.4);
        }

    .btn-submit {
        background: linear-gradient(135deg, #8b45ff, #6366f1);
        color: white;
        border: none;
        padding: 14px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
