@using WebDuLichDaLat.Models
@model IEnumerable<WebDuLichDaLat.Models.TouristPlace>

@{
    var categories = ViewBag.Categories as IEnumerable<WebDuLichDaLat.Models.Category>;
    var regions = ViewBag.Manufacturers as IEnumerable<WebDuLichDaLat.Models.Region>;
    var touristPlacesList = Model?.ToList() ?? new List<WebDuLichDaLat.Models.TouristPlace>();
    var touristPlacesJson = ViewBag.TouristPlacesJson as string;
    
    // Hide navbar on map page
    ViewBag.HideNavbar = true;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bản đồ địa điểm - Đà Lạt</title>
    
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- Modern Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
</head>
<body>
    <!-- Main Container -->
    <div class="map-page-container">
        <!-- Sidebar -->
        <div class="map-sidebar" id="mapSidebar">
            <!-- Header -->
            <div class="sidebar-header">
                <div class="header-content">
                    <div class="logo-section">
                        <div class="logo-icon">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div class="logo-text">
                            <h2>Khám Phá Đà Lạt</h2>
                            <p>@touristPlacesList.Count() địa điểm</p>
                        </div>
                    </div>
                    <button class="close-btn" onclick="toggleSidebar()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <!-- Search -->
            <div class="search-section">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="placeSearch" class="search-input" placeholder="Tìm kiếm địa điểm...">
                    <button class="clear-btn" id="clearBtn" onclick="clearSearch()">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                </div>
            </div>

            <!-- Filters -->
            <div class="filter-section">
                <h4><i class="bi bi-funnel me-2"></i>Bộ lọc</h4>
                <div class="filter-pills">
                    <div class="pill active" data-category="" onclick="filterByCategory('')">
                        <i class="bi bi-grid"></i>
                        <span>Tất cả</span>
                    </div>
                    @if (categories != null && categories.Any())
                    {
                        @foreach (var cat in categories)
                        {
                            <div class="pill" data-category="@cat.Id" onclick="filterByCategory('@cat.Id')">
                                <i class="bi bi-tag"></i>
                                <span>@cat.Name</span>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Places List -->
            <div class="places-section">
                <div class="places-header">
                    <h4>Danh sách địa điểm</h4>
                </div>
                
                <div class="places-list" id="placesList">
                    <!-- Debug info -->
                    <div style="color: white; padding: 10px; background: rgba(255,0,0,0.3); margin-bottom: 10px; border-radius: 10px;">
                        Debug: Có @touristPlacesList.Count() địa điểm trong dữ liệu
                    </div>
                    
                    @if (touristPlacesList.Any())
                    {
                        @foreach (var place in touristPlacesList)
                        {
                            <div class="place-card" 
                                 data-place-id="@place.Id"
                                 data-lat="@place.Latitude"
                                 data-lng="@place.Longitude"
                                 data-category="@place.CategoryId"
                                 data-name="@place.Name.ToLower()"
                                 onclick="selectPlace('@place.Id', @place.Latitude, @place.Longitude, '@Html.Raw(place.Name.Replace("'", "\\'"))')">
                                
                                <div class="card-image">
                                    @if (!string.IsNullOrEmpty(place.ImageUrl))
                                    {
                                        var imageUrl = place.ImageUrl.StartsWith("~") ? Url.Content(place.ImageUrl) : place.ImageUrl;
                                        <img src="@imageUrl" alt="@place.Name" onerror="this.src='/Images/default-place.jpg'">
                                    }
                                    else
                                    {
                                        <div class="placeholder-image">
                                            <i class="bi bi-geo-alt"></i>
                                        </div>
                                    }
                                    <div class="rating-badge">
                                        <i class="bi bi-star-fill"></i>
                                        <span>4.5</span>
                                    </div>
                                </div>
                                
                                <div class="card-content">
                                    <h5 class="place-name">@place.Name</h5>
                                    <div class="category-badge">
                                        @(place.Category?.Name ?? "Địa điểm")
                                    </div>
                                    
                                    <div class="place-meta">
                                        @if (place.Region != null)
                                        {
                                            <div class="meta-item">
                                                <i class="bi bi-pin-map"></i>
                                                <span>@place.Region.Name</span>
                                            </div>
                                        }
                                        <div class="meta-item">
                                            <i class="bi bi-eye"></i>
                                            <span>@((new Random().Next(100, 999)).ToString()) lượt xem</span>
                                        </div>
                                    </div>
                                    
                                    <div class="card-actions">
                                        <button class="action-btn primary" onclick="event.stopPropagation(); viewDetails('@place.Id')">
                                            <i class="bi bi-eye"></i>
                                            Chi tiết
                                        </button>
                                        <button class="action-btn secondary" onclick="event.stopPropagation(); addToFavorites('@place.Id')">
                                            <i class="bi bi-heart"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <h4>Không có địa điểm nào</h4>
                            <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Map Container -->
        <div class="map-container">
            <!-- Map Controls -->
            <div class="map-controls">
                <div class="control-group top-left">
                    <button class="control-btn" onclick="toggleSidebar()" title="Toggle Sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <button class="control-btn" onclick="goHome()" title="Về trang chủ">
                        <i class="bi bi-house"></i>
                    </button>
                </div>
                
                <div class="control-group top-right">
                    <button class="control-btn" onclick="centerMap()" title="Về trung tâm">
                        <i class="bi bi-geo-alt"></i>
                    </button>
                </div>
                
                <div class="control-group bottom-right">
                    <button class="control-btn" onclick="zoomIn()" title="Phóng to">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                    <button class="control-btn" onclick="zoomOut()" title="Thu nhỏ">
                        <i class="bi bi-dash-lg"></i>
                    </button>
                </div>
            </div>

            <!-- Map -->
            <div id="map" class="map-canvas"></div>

            <!-- Info Panel -->
            <div class="info-panel" id="infoPanel">
                <div class="info-content">
                    <h4>Chọn một địa điểm</h4>
                    <p>Click vào marker trên bản đồ hoặc chọn từ danh sách bên trái để xem thông tin chi tiết</p>
                </div>
            </div>
        </div>

        <!-- Mobile Toggle -->
        <button class="mobile-toggle" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>
    </div>
</body>
</html>

<!-- Styles -->
<style>
    :root {
        --primary-purple: #667eea;
        --secondary-purple: #764ba2;
        --accent-pink: #ff6b9d;
        --accent-gold: #ffd700;
        --glass-bg: rgba(255, 255, 255, 0.1);
        --glass-border: rgba(255, 255, 255, 0.2);
        --dark-bg: #0f0f23;
        --darker-bg: #0a0a1a;
        --text-primary: #ffffff;
        --text-secondary: #b8b8d4;
        --shadow-glow: 0 8px 32px rgba(102, 126, 234, 0.3);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: linear-gradient(135deg, var(--dark-bg) 0%, var(--darker-bg) 100%);
        color: var(--text-primary);
        overflow: hidden;
        height: 100vh;
    }

    /* Main Container */
    .map-page-container {
        display: flex;
        height: 100vh;
        position: relative;
        background: linear-gradient(135deg, var(--primary-purple), var(--secondary-purple));
    }

    /* Sidebar */
    .map-sidebar {
        width: 400px;
        background: rgba(15, 15, 35, 0.95);
        backdrop-filter: blur(20px);
        border-right: 1px solid var(--glass-border);
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease;
        z-index: 1000;
        box-shadow: var(--shadow-glow);
    }

    .map-sidebar.collapsed {
        transform: translateX(-100%);
    }

    /* Sidebar Header */
    .sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.05);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-section {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .logo-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .logo-text h2 {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 5px;
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .logo-text p {
        font-size: 14px;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .close-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-primary);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .close-btn:hover {
        background: rgba(255, 107, 157, 0.2);
        transform: scale(1.05);
    }

    /* Search Section */
    .search-section {
        padding: 20px;
        border-bottom: 1px solid var(--glass-border);
    }

    .search-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-input {
        width: 100%;
        padding: 15px 50px 15px 50px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 15px;
        color: var(--text-primary);
        font-size: 16px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--accent-pink);
        box-shadow: 0 0 20px rgba(255, 107, 157, 0.3);
        background: rgba(255, 255, 255, 0.15);
    }

    .search-input::placeholder {
        color: var(--text-secondary);
    }

    .search-icon {
        position: absolute;
        left: 18px;
        color: var(--text-secondary);
        font-size: 18px;
        z-index: 2;
    }

    .clear-btn {
        position: absolute;
        right: 15px;
        background: none;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 16px;
        transition: color 0.3s ease;
        z-index: 2;
    }

    .clear-btn:hover {
        color: var(--accent-pink);
    }

    /* Filter Section */
    .filter-section {
        padding: 20px;
        border-bottom: 1px solid var(--glass-border);
    }

    .filter-section h4 {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 15px;
        color: var(--text-primary);
    }

    .filter-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .pill {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 15px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid var(--glass-border);
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 14px;
        font-weight: 500;
    }

    .pill:hover {
        background: rgba(255, 107, 157, 0.2);
        border-color: var(--accent-pink);
        transform: translateY(-2px);
    }

    .pill.active {
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        border-color: transparent;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    /* Places Section */
    .places-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .places-header {
        padding: 20px;
        border-bottom: 1px solid var(--glass-border);
    }

    .places-header h4 {
        font-size: 18px;
        font-weight: 600;
        color: var(--text-primary);
    }

    /* Places List */
    .places-list {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-height: 200px; /* Debug: ensure minimum height */
    }

    .places-list::-webkit-scrollbar {
        width: 6px;
    }

    .places-list::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .places-list::-webkit-scrollbar-thumb {
        background: var(--accent-pink);
        border-radius: 3px;
    }

    /* Place Card */
    .place-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        min-height: 300px; /* Debug: ensure minimum height */
        display: block !important; /* Debug: force display */
        visibility: visible !important; /* Debug: force visibility */
    }

    .place-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
        border-color: var(--accent-pink);
    }

    .place-card.selected {
        border-color: var(--accent-pink);
        box-shadow: 0 0 20px rgba(255, 107, 157, 0.5);
        transform: translateY(-5px);
    }

    .card-image {
        position: relative;
        height: 150px;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .place-card:hover .card-image img {
        transform: scale(1.1);
    }

    .placeholder-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--primary-purple), var(--secondary-purple));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: rgba(255, 255, 255, 0.7);
    }

    .rating-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(10px);
        padding: 5px 10px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        color: var(--accent-gold);
    }

    .card-content {
        padding: 20px;
    }

    .place-name {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 10px 0;
    }

    .category-badge {
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 12px;
        font-weight: 600;
        color: white;
        display: inline-block;
        margin-bottom: 15px;
    }

    .place-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 15px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: var(--text-secondary);
    }

    .meta-item i {
        color: var(--accent-pink);
        font-size: 16px;
    }

    .card-actions {
        display: flex;
        gap: 10px;
    }

    .action-btn {
        flex: 1;
        padding: 10px 15px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .action-btn.primary {
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        color: white;
    }

    .action-btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .action-btn.secondary {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid var(--glass-border);
        color: var(--text-primary);
        flex: 0 0 auto;
        width: 45px;
    }

    .action-btn.secondary:hover {
        background: rgba(255, 107, 157, 0.2);
        border-color: var(--accent-pink);
        color: var(--accent-pink);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-secondary);
    }

    .empty-icon {
        font-size: 60px;
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-state h4 {
        font-size: 20px;
        margin-bottom: 10px;
        color: var(--text-primary);
    }

    /* Map Container */
    .map-container {
        flex: 1;
        position: relative;
        overflow: hidden;
    }

    .map-canvas {
        width: 100%;
        height: 100%;
        filter: hue-rotate(220deg) saturate(0.8) brightness(0.9);
    }

    /* Map Controls */
    .map-controls {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 1000;
    }

    .control-group {
        position: absolute;
        display: flex;
        gap: 10px;
        pointer-events: auto;
    }

    .control-group.top-left {
        top: 20px;
        left: 20px;
        flex-direction: column;
    }

    .control-group.top-right {
        top: 20px;
        right: 20px;
        flex-direction: column;
    }

    .control-group.bottom-right {
        bottom: 20px;
        right: 20px;
        flex-direction: column;
    }

    .control-btn {
        width: 50px;
        height: 50px;
        background: rgba(15, 15, 35, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 15px;
        color: var(--text-primary);
        font-size: 18px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    }

    .control-btn:hover {
        background: rgba(255, 107, 157, 0.2);
        border-color: var(--accent-pink);
        transform: scale(1.05);
    }

    /* Info Panel */
    .info-panel {
        position: absolute;
        bottom: 20px;
        left: 20px;
        width: 300px;
        background: rgba(15, 15, 35, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 20px;
        box-shadow: var(--shadow-glow);
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s ease;
        pointer-events: auto;
    }

    .info-panel.active {
        transform: translateY(0);
        opacity: 1;
    }

    .info-content h4 {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 10px;
        color: var(--text-primary);
    }

    .info-content p {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    /* Mobile Toggle */
    .mobile-toggle {
        display: none;
        position: fixed;
        top: 20px;
        left: 20px;
        width: 50px;
        height: 50px;
        background: rgba(15, 15, 35, 0.9);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 15px;
        color: var(--text-primary);
        font-size: 18px;
        cursor: pointer;
        z-index: 1001;
        transition: all 0.3s ease;
    }

    .mobile-toggle:hover {
        background: rgba(255, 107, 157, 0.2);
        border-color: var(--accent-pink);
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .map-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            z-index: 1002;
            width: 100%;
            max-width: 400px;
        }

        .mobile-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .control-group.top-left {
            top: 80px;
        }
    }

    @@media (max-width: 480px) {
        .map-sidebar {
            width: 100%;
            max-width: none;
        }

        .places-list {
            padding: 15px;
        }

        .place-card {
            border-radius: 15px;
        }

        .card-content {
            padding: 15px;
        }

        .info-panel {
            left: 10px;
            right: 10px;
            width: auto;
        }
    }

    /* Custom Leaflet Styles */
    .leaflet-popup-content-wrapper {
        background: rgba(15, 15, 35, 0.95) !important;
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 15px !important;
        color: var(--text-primary) !important;
        box-shadow: var(--shadow-glow) !important;
    }

    .leaflet-popup-content {
        color: var(--text-primary) !important;
        font-family: 'Plus Jakarta Sans', sans-serif !important;
    }

    .leaflet-popup-tip {
        background: rgba(15, 15, 35, 0.95) !important;
        border: 1px solid var(--glass-border) !important;
    }

    .leaflet-control-zoom {
        display: none !important;
    }

    .leaflet-control-attribution {
        background: rgba(15, 15, 35, 0.8) !important;
        color: var(--text-secondary) !important;
        border-radius: 10px !important;
        backdrop-filter: blur(10px);
    }

    /* Custom marker styles */
    .custom-marker {
        background: transparent;
        border: none;
    }

    .marker-pin {
        position: relative;
        width: 30px;
        height: 40px;
    }

    .marker-icon {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        border-radius: 50% 50% 50% 0;
        transform: translateX(-50%) rotate(-45deg);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .marker-icon i {
        transform: rotate(45deg);
        color: white;
        font-size: 16px;
    }

    /* Cluster marker styles */
    .marker-cluster {
        background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink));
        border-radius: 50%;
        text-align: center;
        color: white;
        font-weight: bold;
        border: 3px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .marker-cluster-small {
        width: 40px;
        height: 40px;
    }

    .marker-cluster-medium {
        width: 50px;
        height: 50px;
    }

    .marker-cluster-large {
        width: 60px;
        height: 60px;
    }

    .cluster-inner {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        font-size: 14px;
        font-weight: 700;
    }
</style>

<!-- Leaflet JavaScript -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>

<script>
    // Global variables
    let map;
    let markers = [];
    let markerClusterGroup;
    let sidebarCollapsed = false;
    
    // Tourist places data
    const touristPlaces = @Html.Raw(touristPlacesJson ?? "[]");
    
    // Initialize when page loads
    document.addEventListener('DOMContentLoaded', function() {
        initializeMap();
        initializeEventListeners();
        console.log('Map initialized with', touristPlaces.length, 'places');
    });
    
    // Initialize Leaflet map
    function initializeMap() {
        try {
            // Create map centered on Da Lat
            map = L.map('map', {
                center: [11.9404, 108.4583], // Da Lat coordinates
                zoom: 13,
                zoomControl: false,
                attributionControl: true
            });
            
            // Add OpenStreetMap tile layer
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                maxZoom: 18
            }).addTo(map);
            
            // Initialize marker cluster group
            markerClusterGroup = L.markerClusterGroup({
                chunkedLoading: true,
                spiderfyOnMaxZoom: true,
                showCoverageOnHover: false,
                zoomToBoundsOnClick: true,
                maxClusterRadius: 50,
                iconCreateFunction: function(cluster) {
                    const count = cluster.getChildCount();
                    let size = 'small';
                    if (count > 10) size = 'medium';
                    if (count > 25) size = 'large';
                    
                    return L.divIcon({
                        html: `<div class="cluster-inner">${count}</div>`,
                        className: `marker-cluster marker-cluster-${size}`,
                        iconSize: [40, 40]
                    });
                }
            });
            
            // Add markers for tourist places
            addMarkersToMap();
            
            // Add cluster group to map
            map.addLayer(markerClusterGroup);
            
            console.log('Map initialized successfully');
        } catch (error) {
            console.error('Error initializing map:', error);
        }
    }
    
    // Add markers to map
    function addMarkersToMap() {
        if (!touristPlaces || touristPlaces.length === 0) {
            console.log('No tourist places data available');
            return;
        }
        
        touristPlaces.forEach(place => {
            if (place.Latitude && place.Longitude) {
                // Create custom marker icon
                const customIcon = L.divIcon({
                    className: 'custom-marker',
                    html: `
                        <div class="marker-pin">
                            <div class="marker-icon">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                        </div>
                    `,
                    iconSize: [30, 40],
                    iconAnchor: [15, 40],
                    popupAnchor: [0, -40]
                });
                
                // Create marker
                const marker = L.marker([place.Latitude, place.Longitude], {
                    icon: customIcon
                });
                
                // Create popup content
                const popupContent = createPopupContent(place);
                marker.bindPopup(popupContent, {
                    maxWidth: 300,
                    className: 'custom-popup'
                });
                
                // Add click event
                marker.on('click', function() {
                    selectPlace(place.Id, place.Latitude, place.Longitude, place.Name);
                });
                
                // Store place data with marker
                marker.placeData = place;
                markers.push(marker);
                
                // Add to cluster group
                markerClusterGroup.addLayer(marker);
            }
        });
        
        console.log('Added', markers.length, 'markers to map');
    }
    
    // Create popup content
    function createPopupContent(place) {
        const imageUrl = place.ImageUrl ? 
            (place.ImageUrl.startsWith('~') ? place.ImageUrl.substring(1) : place.ImageUrl) : 
            '/Images/default-place.jpg';
            
        return `
            <div style="font-family: 'Plus Jakarta Sans', sans-serif;">
                <div style="width: 100%; height: 120px; overflow: hidden; border-radius: 10px; margin-bottom: 15px;">
                    <img src="${imageUrl}" alt="${place.Name}" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='/Images/default-place.jpg'">
                </div>
                <div>
                    <h4 style="font-size: 18px; font-weight: 700; margin-bottom: 10px; color: var(--text-primary);">${place.Name}</h4>
                    <div style="display: flex; flex-direction: column; gap: 5px; margin-bottom: 15px;">
                        <div style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-secondary);">
                            <i class="bi bi-tag" style="color: var(--accent-pink);"></i>
                            <span>${place.Category?.Name || 'Địa điểm'}</span>
                        </div>
                        ${place.Region ? `
                        <div style="display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-secondary);">
                            <i class="bi bi-pin-map" style="color: var(--accent-pink);"></i>
                            <span>${place.Region.Name}</span>
                        </div>
                        ` : ''}
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button onclick="viewDetails('${place.Id}')" style="flex: 1; padding: 8px 12px; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink)); color: white; display: flex; align-items: center; justify-content: center; gap: 5px;">
                            <i class="bi bi-eye"></i> Xem chi tiết
                        </button>
                        <button onclick="addToFavorites('${place.Id}')" style="background: rgba(255, 255, 255, 0.1); border: 1px solid var(--glass-border); color: var(--text-primary); flex: 0 0 auto; width: 40px; padding: 8px 12px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-heart"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
    }
    
    // Initialize event listeners
    function initializeEventListeners() {
        // Search functionality
        const searchInput = document.getElementById('placeSearch');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                filterPlaces();
            });
        }
        
        // Clear search button
        const clearBtn = document.getElementById('clearBtn');
        if (clearBtn) {
            clearBtn.addEventListener('click', function() {
                if (searchInput) {
                    searchInput.value = '';
                    filterPlaces();
                }
            });
        }
    }
    
    // Filter places based on search and category
    function filterPlaces() {
        const searchInput = document.getElementById('placeSearch');
        const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
        const activeCategory = document.querySelector('.pill.active')?.dataset.category || '';
        const placeCards = document.querySelectorAll('.place-card');
        
        placeCards.forEach(card => {
            const placeName = card.dataset.name || '';
            const placeCategory = card.dataset.category || '';
            
            const matchesSearch = !searchTerm || placeName.includes(searchTerm);
            const matchesCategory = !activeCategory || placeCategory === activeCategory;
            
            if (matchesSearch && matchesCategory) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
        
        // Update map markers
        updateMapMarkers(searchTerm, activeCategory);
    }
    
    // Update map markers based on filters
    function updateMapMarkers(searchTerm, categoryId) {
        if (!markerClusterGroup) return;
        
        markerClusterGroup.clearLayers();
        
        markers.forEach(marker => {
            const place = marker.placeData;
            const matchesSearch = !searchTerm || place.Name.toLowerCase().includes(searchTerm);
            const matchesCategory = !categoryId || place.CategoryId.toString() === categoryId;
            
            if (matchesSearch && matchesCategory) {
                markerClusterGroup.addLayer(marker);
            }
        });
    }
    
    // Filter by category
    function filterByCategory(categoryId) {
        // Update active pill
        document.querySelectorAll('.pill').forEach(pill => {
            pill.classList.remove('active');
        });
        const targetPill = document.querySelector(`[data-category="${categoryId}"]`);
        if (targetPill) {
            targetPill.classList.add('active');
        }
        
        // Filter places
        filterPlaces();
    }
    
    // Select place
    function selectPlace(placeId, lat, lng, name) {
        // Highlight selected card
        document.querySelectorAll('.place-card').forEach(card => {
            card.classList.remove('selected');
        });
        const selectedCard = document.querySelector(`[data-place-id="${placeId}"]`);
        if (selectedCard) {
            selectedCard.classList.add('selected');
        }
        
        // Center map on place
        if (map) {
            map.setView([lat, lng], 16);
        }
        
        // Show info panel
        showInfoPanel(name, lat, lng);
        
        // Find and open popup
        markers.forEach(marker => {
            if (marker.placeData.Id.toString() === placeId.toString()) {
                marker.openPopup();
            }
        });
    }
    
    // Show info panel
    function showInfoPanel(name, lat, lng) {
        const panel = document.getElementById('infoPanel');
        const content = panel.querySelector('.info-content');
        
        if (content) {
            content.innerHTML = `
                <h4>${name}</h4>
                <p>Tọa độ: ${lat.toFixed(6)}, ${lng.toFixed(6)}</p>
                <div style="margin-top: 15px;">
                    <button onclick="centerMap()" style="background: linear-gradient(135deg, var(--primary-purple), var(--accent-pink)); border: none; border-radius: 10px; padding: 10px 15px; color: white; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-geo-alt"></i> Về trung tâm
                    </button>
                </div>
            `;
        }
        
        if (panel) {
            panel.classList.add('active');
        }
    }
    
    // Toggle sidebar
    function toggleSidebar() {
        const sidebar = document.getElementById('mapSidebar');
        if (sidebar) {
            sidebarCollapsed = !sidebarCollapsed;
            
            if (sidebarCollapsed) {
                sidebar.classList.add('collapsed');
            } else {
                sidebar.classList.remove('collapsed');
            }
        }
    }
    
    // Center map
    function centerMap() {
        if (map) {
            map.setView([11.9404, 108.4583], 13);
        }
        const panel = document.getElementById('infoPanel');
        if (panel) {
            panel.classList.remove('active');
        }
    }
    
    // Zoom in
    function zoomIn() {
        if (map) {
            map.zoomIn();
        }
    }
    
    // Zoom out
    function zoomOut() {
        if (map) {
            map.zoomOut();
        }
    }
    
    // Go home
    function goHome() {
        window.location.href = '/';
    }
    
    // View details
    function viewDetails(placeId) {
        window.location.href = `/TouristPlace/Display/${placeId}`;
    }
    
    // Add to favorites
    function addToFavorites(placeId) {
        console.log('Added to favorites:', placeId);
        showNotification('Đã thêm vào yêu thích!');
    }
    
    // Clear search
    function clearSearch() {
        const searchInput = document.getElementById('placeSearch');
        if (searchInput) {
            searchInput.value = '';
            filterPlaces();
        }
    }
    
    // Show notification
    function showNotification(message) {
        const notification = document.createElement('div');
        notification.innerHTML = `
            <div style="display: flex; align-items: center; gap: 10px;">
                <i class="bi bi-check-circle"></i>
                <span>${message}</span>
            </div>
        `;
        
        notification.style.cssText = `
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(15, 15, 35, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 15px;
            padding: 15px 20px;
            color: var(--text-primary);
            z-index: 10000;
            transform: translateX(100%);
            transition: transform 0.3s ease;
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.transform = 'translateX(0)';
        }, 100);
        
        setTimeout(() => {
            notification.style.transform = 'translateX(100%)';
            setTimeout(() => {
                if (document.body.contains(notification)) {
                    document.body.removeChild(notification);
                }
            }, 300);
        }, 3000);
    }
</script>