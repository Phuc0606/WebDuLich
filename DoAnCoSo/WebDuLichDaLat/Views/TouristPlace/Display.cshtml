</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Initialize OpenStreetMap with Leaflet
            initializeMiniMap();
            
            // Interactive Star Rating
            const stars = document.querySelectorAll('.star-interactive');
            const ratingInput = document.getElementById('ratingInput');
            let currentRating = 0;

            stars.forEach((star, index) => {
                star.addEventListener('mouseenter', function() {
                    highlightStars(index + 1);
                });

                star.addEventListener('mouseleave', function() {
                    highlightStars(currentRating);
                });

                star.addEventListener('click', function() {
                    currentRating = index + 1;
                    ratingInput.value = currentRating;
                    highlightStars(currentRating);
                });
            });

            function highlightStars(rating) {
                stars.forEach((star, index) => {
                    if (index < rating) {
                        star.classList.remove('fa-regular');
                        star.classList.add('fa-solid', 'active');
                    } else {
                        star.classList.remove('fa-solid', 'active');
                        star.classList.add('fa-regular');
                    }
                });
            }

            // Rating Form Submission
            const ratingForm = document.getElementById('form-rating');
            if (ratingForm) {
                ratingForm.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    
                    if (currentRating === 0) {
                        showNotification('Vui lòng chọn số sao đánh giá!', 'warning');
                        return;
                    }

                    try {
                        const formData = new FormData(this);
                        const response = await fetch(this.action, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                            }
                        });

                        if (response.ok) {
                            showNotification('Cảm ơn bạn đã đánh giá!', 'success');
                            // Reset form
                            currentRating = 0;
                            ratingInput.value = 0;
                            highlightStars(0);
                        } else {
                            showNotification('Có lỗi xảy ra. Vui lòng thử lại!', 'error');
                        }
                    } catch (error) {
                        console.error('Rating error:', error);
                        showNotification('Có lỗi xảy ra. Vui lòng thử lại!', 'error');
                    }
                });
            }

            // Smooth Scroll for Scroll Indicator
            const scrollIndicator = document.querySelector('.scroll-indicator');
            if (scrollIndicator) {
                scrollIndicator.addEventListener('click', function() {
                    document.getElementById('place-content').scrollIntoView({
                        behavior: 'smooth'
                    });
                });
            }

            // Parallax Effect for Hero Background
            window.addEventListener('scroll', function() {
                const scrolled = window.pageYOffset;
                const heroBackground = document.querySelector('.hero-bg');
                if (heroBackground) {
                    heroBackground.style.transform = `translateY(${scrolled * 0.5}px)`;
                }
            });

            // Image Gallery Enhancement
            const carouselImages = document.querySelectorAll('.carousel-image');
            carouselImages.forEach(img => {
                img.addEventListener('error', function() {
                    this.style.display = 'none';
                    // Create fallback placeholder
                    const placeholder = document.createElement('div');
                    placeholder.className = 'image-placeholder';
                    placeholder.style.cssText = `
                        width: 100%; 
                        height: 400px; 
                        background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%); 
                        display: flex; 
                        align-items: center; 
                        justify-content: center;
                    `;
                    placeholder.innerHTML = `
                        <div style="background: rgba(255,255,255,0.15); backdrop-filter: blur(15px); border-radius: 25px; padding: 40px; border: 1px solid rgba(255,255,255,0.2);">
                            <i class="bi bi-geo-alt" style="font-size: 80px; color: rgba(255,255,255,0.9);"></i>
                        </div>
                    `;
                    this.parentNode.appendChild(placeholder);
                });
            });
        });

        // Initialize Mini Map with OpenStreetMap
        let miniMap;
        function initializeMiniMap() {
            try {
                // Default coordinates for Đà Lạt
                const defaultLat = 11.9404;
                const defaultLng = 108.4583;
                
                // Initialize map
                miniMap = L.map('miniMap', {
                    zoomControl: false,
                    attributionControl: false,
                    scrollWheelZoom: false,
                    doubleClickZoom: false,
                    dragging: false,
                    touchZoom: false,
                    boxZoom: false,
                    keyboard: false
                }).setView([defaultLat, defaultLng], 15);

                // Add dark theme tile layer
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© OpenStreetMap contributors'
                }).addTo(miniMap);

                // Create custom marker
                const customIcon = L.divIcon({
                    className: 'custom-marker',
                    iconSize: [30, 30],
                    iconAnchor: [15, 30],
                    popupAnchor: [0, -30]
                });

                // Add marker for the place
                const marker = L.marker([defaultLat, defaultLng], { icon: customIcon }).addTo(miniMap);
                
                // Add popup with place name
                marker.bindPopup(`
                    <div style="text-align: center; padding: 5px;">
                        <strong style="color: white;">@Html.Raw(Model.Name.Replace("'", "\\'"))</strong><br>
                        <small style="color: rgba(255,255,255,0.8);">@(Model.Region?.Name ?? "Đà Lạt")</small>
                    </div>
                `);

                // Try to geocode the place name for more accurate location
                geocodePlace('@Html.Raw(Model.Name.Replace("'", "\\'"))');
                
            } catch (error) {
                console.error('Error initializing map:', error);
            }
        }

        // Geocode place name to get accurate coordinates
        async function geocodePlace(placeName) {
            try {
                const query = encodeURIComponent(placeName + ' Đà Lạt Vietnam');
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${query}&limit=1`);
                const data = await response.json();
                
                if (data && data.length > 0) {
                    const lat = parseFloat(data[0].lat);
                    const lng = parseFloat(data[0].lon);
                    
                    // Update map view and marker position
                    miniMap.setView([lat, lng], 15);
                    
                    // Clear existing markers and add new one
                    miniMap.eachLayer(function(layer) {
                        if (layer instanceof L.Marker) {
                            miniMap.removeLayer(layer);
                        }
                    });
                    
                    const customIcon = L.divIcon({
                        className: 'custom-marker',
                        iconSize: [30, 30],
                        iconAnchor: [15, 30],
                        popupAnchor: [0, -30]
                    });
                    
                    const marker = L.marker([lat, lng], { icon: customIcon }).addTo(miniMap);
                    marker.bindPopup(`
                        <div style="text-align: center; padding: 5px;">
                            <strong style="color: white;">@Html.Raw(Model.Name.Replace("'", "\\'"))</strong><br>
                            <small style="color: rgba(255,255,255,0.8);">@(Model.Region?.Name ?? "Đà Lạt")</small>
                        </div>
                    `);
                }
            } catch (error) {
                console.error('Geocoding error:', error);
            }
        }

        // Share Function
        function sharePlace() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.Name',
                    text: 'Khám phá địa điểm tuyệt vời này tại Đà Lạt!',
                    url: window.location.href
                }).catch(console.error);
            } else {
                // Fallback: Copy to clipboard
                navigator.clipboard.writeText(window.location.href).then(() => {
                    showNotification('Đã sao chép liên kết!', 'success');
                }).catch(() => {
                    showNotification('Không thể sao chép liên kết!', 'error');
                });
            }
        }

        // Map Functions
        function openInGoogleMaps() {
            const placeName = '@Html.Raw(Model.Name.Replace("'", "\\'"))';
            const searchQuery = encodeURIComponent(placeName + ' Đà Lạt');
            const googleMapsUrl = `https://www.google.com/maps/search/${searchQuery}`;
            window.open(googleMapsUrl, '_blank');
        }

        function getDirections() {
            const placeName = '@Html.Raw(Model.Name.Replace("'", "\\'"))';
            const searchQuery = encodeURIComponent(placeName + ' Đà Lạt');
            
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    function(position) {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
                        const directionsUrl = `https://www.google.com/maps/dir/${lat},${lng}/${searchQuery}`;
                        window.open(directionsUrl, '_blank');
                    },
                    function(error) {
                        // Fallback: Open directions without current location
                        const directionsUrl = `https://www.google.com/maps/dir//${searchQuery}`;
                        window.open(directionsUrl, '_blank');
                    }
                );
            } else {
                // Fallback: Open directions without current location
                const directionsUrl = `https://www.google.com/maps/dir//${searchQuery}`;
                window.open(directionsUrl, '_blank');
            }
        }

        // Notification System
        function showNotification(message, type = 'info') {
            // Remove existing notifications
            const existingNotifications = document.querySelectorAll('.notification');
            existingNotifications.forEach(n => n.remove());

            const notification = document.createElement('div');
            notification.className = `notification notification-${type}`;
            notification.style.cssText = `
                position: fixed;
                top: 100px;
                right: 20px;
                background: ${type === 'success' ? 'linear-gradient(135deg, #4CAF50, #45a049)' : 
                            type === 'error' ? 'linear-gradient(135deg, #f44336, #da190b)' : 
                            type === 'warning' ? 'linear-gradient(135deg, #ff9800, #f57c00)' : 
                            'linear-gradient(135deg, #2196F3, #0b7dda)'};
                color: white;
                padding: 15px 25px;
                border-radius: 25px;
                box-shadow: 0 15px 35px rgba(0,0,0,0.3);
                backdrop-filter: blur(15px);
                z-index: 9998;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-weight: 600;
                font-size: 14px;
                transform: translateX(400px);
                transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
                max-width: 300px;
            `;
            notification.textContent = message;

            document.body.appendChild(notification);

            // Animate in
            setTimeout(() => {
                notification.style.transform = 'translateX(0)';
            }, 100);

            // Auto remove
            setTimeout(() => {
                notification.style.transform = 'translateX(400px)';
                setTimeout(() => {
                    notification.remove();
                }, 400);
            }, 3000);
        }

        // Enhanced Form Submissions
        document.querySelectorAll('form[asp-controller="Favorite"]').forEach(form => {
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                try {
                    const formData = new FormData(this);
                    const response = await fetch(this.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    });

                    if (response.ok) {
                        showNotification('Đã thêm vào danh sách yêu thích!', 'success');
                        // Update button state
                        const button = this.querySelector('button');
                        button.innerHTML = '<i class="bi bi-heart-fill me-2"></i>Đã yêu thích';
                        button.style.background = 'linear-gradient(135deg, #4CAF50, #45a049)';
                    } else {
                        showNotification('Có lỗi xảy ra. Vui lòng thử lại!', 'error');
                    }
                } catch (error) {
                    console.error('Favorite error:', error);
                    showNotification('Có lỗi xảy ra. Vui lòng thử lại!', 'error');
                }
            });
        });
    </script>
}